#!/usr/bin/env bun
/**
 * dispatcher — watches the board API, picks active cards, runs AM iterations.
 *
 * Loop every 5 seconds:
 *   1. GET /api/cards → filter backlog/in-progress/in-review
 *   2. Pick highest-priority card per state
 *   3. For each card: ensure worktree exists, write work.md, run iteration
 */

import { existsSync, mkdirSync, readdirSync, writeFileSync, symlinkSync, rmSync } from "node:fs";
import { join, resolve } from "node:path";
import { spawnSync } from "node:child_process";
import { AuthError, invokeClaude } from "../agent/src/loop/invoke-claude.ts";

// ── Column prompts (inlined to avoid runtime import issues) ──────────────────

const BACKLOG_PROMPT = `
You are working a card in the BACKLOG column. Your job is to make the work concrete before anyone writes a line of code.

1. Read the card: run \`board show <id>\` to get the title, description, and any existing work log.

2. Classify the task:
   - CODE TASK: the card involves writing, editing, or deleting source files.
   - NON-CODE TASK: the card involves research, documentation, design, or other non-implementation work.

3. For CODE tasks — write research.md:
   - Read the relevant source files using Read/Glob/Grep tools.
   - Identify the specific files and line numbers that need to change.
   - research.md must include at least one file path reference (e.g. src/worker/gates.ts:42).

4. For NON-CODE tasks — write research.md:
   - Use web search to gather relevant sources, prior art, and key findings.
   - research.md must include at least one URL (http://... or https://...) or citation.

5. Write criteria.md — a numbered list of acceptance criteria:
   - Format: \`1. <criterion>\`, \`2. <criterion>\`, etc.
   - Each criterion must be a testable, binary outcome (pass/fail, exists/missing).
   - Be specific. Vague criteria ("it works") will block review.

6. Write todo.md — a flat checklist derived from criteria.md:
   - Format: \`- [ ] <step>\` for each step needed to satisfy the criteria.

7. Attach all files to the card:
   \`board update <id> --attach research.md --attach criteria.md --attach todo.md\`

8. Attempt the gate:
   \`board move <id> in-progress\`
   - If the gate rejects, read the failure message, fix the specific issue, and retry.
`.trim();

const IN_PROGRESS_PROMPT = `
You are working a card in the IN-PROGRESS column. Your job is to implement the work defined by criteria.md.

1. Read context:
   - \`board show <id>\` — card title and state
   - criteria.md — the acceptance criteria (numbered list)
   - research.md — file locations and references from backlog
   - todo.md — the current checklist of steps

2. Work through unchecked items in todo.md one at a time:
   - Implement the change.
   - For CODE tasks: write or update tests covering each criterion. Run \`bun test\` before marking any criterion done.
   - Check off the item in todo.md: change \`- [ ]\` to \`- [x]\`.
   - Rewrite todo.md after each item is completed.

3. When all items in todo.md are checked and tests pass:
   \`board move <id> in-review\`

4. If the gate rejects:
   - Read the failure message carefully.
   - Fix the specific issue (unchecked items, failing tests).
   - Retry the move.
`.trim();

const IN_REVIEW_PROMPT = `
You are working a card in the IN-REVIEW column. Your job is adversarial: assume the implementation is wrong and try to prove it.

1. Read context:
   - criteria.md — the acceptance criteria to verify
   - The latest iter/<n>/agent.log — prior verification attempts

2. Verify each criterion independently:
   - Do not assume the implementation works. Read the code, run commands, check outputs.
   - For CODE tasks: run \`bun test\` and check exit code.
   - If docs/CODE_QUALITY.md exists: scan the implementation against its rules. Flag any violations.

3. Write iter/<n+1>/agent.log with one line per criterion:
   - Pass: \`✓ <criterion text>\`
   - Fail: \`✗ <criterion text>: <specific reason it failed>\`

4. If ALL criteria pass:
   \`board move <id> shipped\`

5. If ANY criterion fails:
   \`board move <id> in-progress --log "<concise summary of what failed and why>"\`
   Do not attempt to fix the failures here — that is in-progress work.
`.trim();

// ── Types ────────────────────────────────────────────────────────────────────

type CardState = "backlog" | "in-progress" | "in-review" | "shipped";
type Priority = "AI" | "critical" | "high" | "normal" | "low";

interface Card {
  id: string;
  title: string;
  state: CardState;
  priority: Priority;
  /** Absolute path to the git worktree for this card. Set once the worktree is created. */
  workDir?: string;
}

// ── Config ───────────────────────────────────────────────────────────────────

const BOARD_URL = process.env.BOARD_URL ?? "http://localhost:3000";
const POLL_INTERVAL_MS = 5_000;
const REPO_ROOT = resolve(import.meta.dir, "..");
const ACTIVE_STATES: CardState[] = ["backlog", "in-progress", "in-review"];

// Priority order (lower index = higher priority). AI is unranked — treated as normal.
const PRIORITY_ORDER: Priority[] = ["critical", "high", "normal", "low"];

// ── Helpers ──────────────────────────────────────────────────────────────────

function priorityRank(p: Priority): number {
  if (p === "AI") return PRIORITY_ORDER.indexOf("normal");
  return PRIORITY_ORDER.indexOf(p);
}

function columnPrompt(state: CardState): string {
  switch (state) {
    case "backlog":     return BACKLOG_PROMPT;
    case "in-progress": return IN_PROGRESS_PROMPT;
    case "in-review":   return IN_REVIEW_PROMPT;
    default:            return "";
  }
}

function worktreePath(cardId: string): string {
  return resolve(REPO_ROOT, "..", `am-${cardId}`);
}

function ensureWorktree(cardId: string): string {
  const dir = worktreePath(cardId);
  if (!existsSync(dir)) {
    console.log(`[dispatch] creating worktree for ${cardId}`);
    // Try with -b first; if the branch already exists (interrupted previous run),
    // fall back to attaching without creating a new branch.
    let result = spawnSync("git", ["worktree", "add", dir, "-b", cardId], { cwd: REPO_ROOT, stdio: "inherit" });
    if (result.status !== 0) {
      result = spawnSync("git", ["worktree", "add", dir, cardId], { cwd: REPO_ROOT, stdio: "inherit" });
    }
    if (result.status !== 0) {
      throw new Error(`git worktree add failed for ${cardId} (exit ${result.status})`);
    }

    // Symlink node_modules from the main worktree so tests can run without npm install
    const mainNodeModules = resolve(REPO_ROOT, "board/node_modules");
    const worktreeNodeModules = join(dir, "board/node_modules");
    if (existsSync(mainNodeModules) && !existsSync(worktreeNodeModules)) {
      symlinkSync(mainNodeModules, worktreeNodeModules);
    }
  }
  return dir;
}

function writeWorkMd(dir: string, card: Card): void {
  const prompt = columnPrompt(card.state);
  const sections = [
    `# Card: ${card.title} (${card.id})`,
    `State: ${card.state}`,
    `Priority: ${card.priority}`,
    "",
    "## Instructions",
    prompt,
  ];

  if (card.state === "backlog" && card.priority === "AI") {
    sections.push(
      "",
      "## Priority Selection (required — priority is AI)",
      `This card was created with AI priority, meaning the creator wants you to determine the appropriate priority.`,
      `As your first action in backlog, run:`,
      `  board update ${card.id} --priority <critical|high|normal|low>`,
      `Choose based on the card title and description. Use critical for blocking/urgent work, high for important near-term work, normal for standard tasks, low for nice-to-haves.`,
    );
  }

  writeFileSync(join(dir, "work.md"), sections.join("\n"), "utf-8");
}

async function fetchActiveCards(): Promise<Card[]> {
  const url = `${BOARD_URL}/api/cards`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(`GET ${url} → ${res.status}`);
  const data = await res.json() as Card[];
  return data.filter((c) => ACTIVE_STATES.includes(c.state));
}

// ── Card concurrency limits (chat is tracked separately — never shares these) ─
const MAX_CARD_CONCURRENCY_GLOBAL = 8;
const MAX_CARD_CONCURRENCY_PER_PROJECT = 5;
const inFlight = new Set<string>();
const inFlightPerProject = new Map<string | null, number>();

// ── Chat concurrency (independent — never blocked by card agents) ─────────────
const MAX_CHAT_CONCURRENCY = 10;
let chatInFlightCount = 0;

function inFlightForProject(projectId: string | null): number {
  return inFlightPerProject.get(projectId) ?? 0;
}

// State priority: in-review first (needs least work to ship), then in-progress, then backlog
const STATE_ORDER: Record<string, number> = { "in-review": 0, "in-progress": 1, "backlog": 2 };

/** Return active cards sorted: in-review > in-progress > backlog, then by priority within each state. */
function pickCards(cards: Card[]): Card[] {
  return [...cards].sort((a, b) => {
    const stateDiff = (STATE_ORDER[a.state] ?? 99) - (STATE_ORDER[b.state] ?? 99);
    if (stateDiff !== 0) return stateDiff;
    return priorityRank(a.priority) - priorityRank(b.priority);
  });
}

// ── RunCard deps (injectable for testing) ────────────────────────────────────

export interface RunCardDeps {
  /** Run one agent iteration. Defaults to the real runIteration. */
  runIterationFn?: (dir: string) => Promise<unknown>;
  /** Update a card on the board. Defaults to calling the board CLI. */
  boardUpdateFn?: (id: string, msg: string) => void;
}

function defaultBoardUpdate(id: string, msg: string): void {
  spawnSync("board", ["update", id, "--log", msg], {
    stdio: "inherit",
    env: process.env,
  });
}

export async function runCard(card: Card, deps: RunCardDeps = {}): Promise<void> {
  const projectKey = card.projectId ?? null;
  inFlight.add(card.id);
  inFlightPerProject.set(projectKey, inFlightForProject(projectKey) + 1);
  console.log(`[dispatch] start ${card.id} ${card.state}`);
  const boardUpdate = deps.boardUpdateFn ?? defaultBoardUpdate;
  try {
    const dir = ensureWorktree(card.id);
    if (!card.workDir) {
      await fetch(`${BOARD_URL}/api/cards/${card.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ workDir: dir }),
      });
    }
    writeWorkMd(dir, card);
    const runIteration = deps.runIterationFn
      ?? (await import(resolve(REPO_ROOT, "agent/src/loop/index.ts"))).runIteration;
    const iterResult = await runIteration(dir) as { usage?: { input_tokens: number; output_tokens: number; cache_read_input_tokens?: number } } | void;
    console.log(`[dispatch] done  ${card.id}`);

    // Record token usage in the board if the iteration returned usage data
    if (iterResult && typeof iterResult === "object" && "usage" in iterResult && iterResult.usage) {
      const iterDir = join(dir, "iter");
      const iterN = existsSync(iterDir)
        ? Math.max(0, ...readdirSync(iterDir).map(d => parseInt(d, 10)).filter(n => !isNaN(n)))
        : 0;
      fetch(`${BOARD_URL}/api/cards/${card.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          tokenLogEntry: {
            iter: iterN,
            inputTokens: iterResult.usage.input_tokens,
            outputTokens: iterResult.usage.output_tokens,
            cacheRead: iterResult.usage.cache_read_input_tokens ?? 0,
            timestamp: new Date().toISOString(),
          },
        }),
      }).catch(() => {});
    }
  } catch (err) {
    if (err instanceof AuthError) {
      console.error(`[dispatch] auth error ${card.id} — logging to board`);
      boardUpdate(card.id, "Claude auth expired — run /login to restore");
      return;
    }
    console.error(`[dispatch] error ${card.id}:`, err);
  } finally {
    inFlight.delete(card.id);
    const cur = inFlightForProject(projectKey) - 1;
    if (cur <= 0) inFlightPerProject.delete(projectKey);
    else inFlightPerProject.set(projectKey, cur);
  }
}

// ── Stale worktree cleanup ───────────────────────────────────────────────────

/**
 * Remove worktrees for cards that are shipped, archived, or no longer exist.
 * Skips cards in backlog/in-progress/in-review (actively being worked).
 * Skips the test fixture worktree `am-test-card-id`.
 * Never throws — errors are caught and logged per-worktree.
 */
async function cleanStaleWorktrees(): Promise<void> {
  const parent = resolve(REPO_ROOT, "..");
  let entries: string[];
  try {
    entries = readdirSync(parent);
  } catch (err) {
    console.error("[dispatch] cleanup: could not read parent directory:", err);
    return;
  }

  // Match directories named am-<uuid> (36-char UUID pattern)
  const uuidPattern = /^am-([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})$/;

  for (const entry of entries) {
    const match = uuidPattern.exec(entry);
    if (!match) continue;
    const cardId = match[1];
    const worktreeDir = resolve(parent, entry);

    try {
      const res = await fetch(`${BOARD_URL}/api/cards/${cardId}`);

      let shouldRemove = false;
      if (res.status === 404) {
        shouldRemove = true;
      } else if (res.ok) {
        const card = await res.json() as { state?: string; archived?: boolean };
        if (card.archived === true || card.state === "shipped") {
          shouldRemove = true;
        }
        // backlog/in-progress/in-review: skip
      }

      if (!shouldRemove) continue;

      console.log(`[dispatch] cleanup ${cardId}`);

      const removeResult = spawnSync("git", ["worktree", "remove", "--force", worktreeDir], {
        cwd: REPO_ROOT,
        stdio: "inherit",
      });
      if (removeResult.status !== 0) {
        // Directory may still exist without git tracking — force-delete it
        try { rmSync(worktreeDir, { recursive: true, force: true }); }
        catch { console.error(`[dispatch] cleanup: rm failed for ${cardId}`); }
      }

      const branchResult = spawnSync("git", ["branch", "-D", cardId], {
        cwd: REPO_ROOT,
        stdio: "inherit",
      });
      if (branchResult.status !== 0) {
        // Branch may already be gone — not fatal
      }
    } catch (err) {
      console.error(`[dispatch] cleanup error for ${cardId}:`, err);
    }
  }
}

// ── Chat queue processor ─────────────────────────────────────────────────────

const CHAT_SYSTEM_PROMPT = `
You are AM, an intelligent assistant integrated with the AM project management board.
You help users answer questions, create/manage work, and set up new projects.

You have access to bash and the \`board\` CLI. Run any commands you need.

## Board CLI commands

  board search [--text <query>] [--state <state>] [--all]
  board show <id>
  board create --title <title> [--priority critical|high|normal|low] [--project-id <id>] [--parent-id <id>]
  board update <id> [--title <title>] [--log <msg>]
  board move <id> <state>
  board archive <id>
  board project list
  board project create --name <name>                          # local git init in workspaces_dir
  board project create --name <name> --repo <github-url>     # clone from GitHub
  board project create --name <name> --repo-dir <local-path> # use existing local dir
  board settings list
  board settings get <key>
  board settings set <key> <value>

## Settings keys
  github_username   — GitHub username
  github_token      — GitHub personal access token (classic)
  github_email      — Git commit email
  workspaces_dir    — Where to clone new project repos (default: ~/workspaces)

## Creating a new project
When user asks to set up a new project:
1. Get the project name from the user
2. If they have a GitHub repo URL: board project create --name "<name>" --repo <url>
   - Check if github_token is set first; if not, guide them through GitHub Setup
3. If no GitHub repo (local project): board project create --name "<name>"
   - This auto-inits a local git repo in workspaces_dir/<slug>
4. Command returns a project id — parse it from output like: "created project <UUID>  (name)"
5. Create an epic card: board create --title "<epic title>" --project-id <UUID> --priority high
6. Create child task cards: board create --title "<task>" --project-id <UUID> --parent-id <epic-UUID>
7. In your CHAT_RESPONSE ALWAYS include:
   - [[project:<UUID>]] link so the user can click to switch to the new project
   - [[card:UUID]] links for the epic and key child cards

IMPORTANT: ALL cards for a project MUST use --project-id. Cards without --project-id appear on the AM Board instead.

## GitHub Setup (when github_token is empty or user asks)
Walk the user through these steps conversationally:
1. Ask if they have a GitHub account. If not, direct them to github.com/join
2. Direct them to: github.com/settings/tokens/new (classic token)
3. Instruct: name it "am-agent", set No Expiration, check ALL scopes (especially repo, workflow, admin:org, write:packages)
4. Ask them to paste the token into chat
5. When they paste it (starts with ghp_ or github_pat_): run:
   board settings set github_token <token>
   board settings set github_username <username>
   git config --global user.name "<username>"
   git config --global user.email "<email>"
   echo "<token>" | gh auth login --with-token  (if gh is available)
6. Confirm setup is complete

## Response rules
- For QUESTIONS: answer directly, no card needed
- For TASKS requiring implementation: ALWAYS break into an epic + child cards, then report them
- When referencing cards: use [[card:UUID]] — becomes a clickable pink link
- When referencing projects: use [[project:UUID]] — becomes a clickable violet link
- You can ask the user follow-up questions — they will reply and you get the full history
- Keep CHAT_RESPONSE concise. Use markdown formatting.

## Task breakdown rule
When the user gives you a task or project to work on, ALWAYS:
1. Create an epic card for the overall goal
2. Break it into 3-7 concrete child cards (specific, actionable tasks)
3. Report all created cards with [[card:UUID]] links
Never leave tasks as a single card — always decompose.

ALWAYS end with exactly one line:
CHAT_RESPONSE: <your complete reply to the user>
`.trim();

interface ChatMessage {
  id: string;
  role: "user" | "assistant";
  content: string;
  status: "pending" | "processing" | "done" | "error";
  replyToId?: string | null;
  createdAt: string;
}

const CHAT_MODEL = "claude-haiku-4-5-20251001";

async function postChatMessage(content: string, opts?: { replyToId?: string }): Promise<string | null> {
  try {
    const res = await fetch(`${BOARD_URL}/api/chat`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ role: "assistant", content, ...opts }),
    });
    if (res.ok) return (await res.json() as { id: string }).id;
  } catch {}
  return null;
}

async function patchChatMessage(id: string, data: Record<string, unknown>): Promise<void> {
  await fetch(`${BOARD_URL}/api/chat/${id}`, {
    method: "PATCH",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(data),
  }).catch(() => {});
}

async function processChat(msg: ChatMessage): Promise<void> {
  // Mark user message as processing
  await patchChatMessage(msg.id, { status: "processing" });

  // Post an immediate acknowledgment so the user sees something right away
  const ACK_MESSAGES = [
    "Got it — one moment.",
    "On it.",
    "Let me look into that.",
    "Sure, give me a sec.",
    "Right, let me think about this.",
    "On it — just a moment.",
    "Working on it.",
    "Let me check that for you.",
    "Understood — one sec.",
    "Got it, I'll take a look.",
    "On it, hold tight.",
    "Sure thing — just a moment.",
    "Let me pull that up.",
    "Yep, on it.",
    "Right — give me a moment.",
    "On it — won't be long.",
    "Let me figure this out.",
    "Sure, just a sec.",
    "Got it — looking into it now.",
    "On it — let me think.",
  ];
  const ackText = ACK_MESSAGES[Math.floor(Math.random() * ACK_MESSAGES.length)];
  const ackId = await postChatMessage(ackText, { replyToId: msg.id });

  try {
    // Fetch conversation history and settings in parallel
    const [histRes, settingsRes] = await Promise.all([
      fetch(`${BOARD_URL}/api/chat?limit=50`),
      fetch(`${BOARD_URL}/api/settings`),
    ]);
    const history: ChatMessage[] = histRes.ok ? await histRes.json() : [];
    const currentSettings: Record<string, string> = settingsRes.ok ? await settingsRes.json() : {};

    // Settings context
    const settingsCtx = [
      `## Current Settings`,
      `github_username: ${currentSettings.github_username || "(not set)"}`,
      `github_token: ${currentSettings.github_token === "***" ? "(set)" : "(NOT SET)"}`,
      `github_email: ${currentSettings.github_email || "(not set)"}`,
      `workspaces_dir: ${currentSettings.workspaces_dir || "~/workspaces"}`,
    ].join("\n");

    // Conversation history (exclude the ack message we just posted)
    const historyLines = history
      .filter(m => m.status === "done" && m.id !== msg.id && m.id !== ackId)
      .map(m => `[${m.role === "user" ? "Human" : "Assistant"}]: ${m.content}`)
      .join("\n");

    const prompt = [
      settingsCtx,
      "",
      historyLines ? `Previous conversation:\n---\n${historyLines}\n---\n` : "",
      `Current message from user:\n${msg.content}`,
    ].filter(Boolean).join("\n");

    // Run Haiku with streaming — push live content to the ack message as events arrive
    let liveContent = "";
    let lastPatch = 0;
    const PATCH_INTERVAL_MS = 600;

    function flushLive(force = false) {
      if (!ackId || !liveContent) return;
      const now = Date.now();
      if (force || now - lastPatch >= PATCH_INTERVAL_MS) {
        lastPatch = now;
        patchChatMessage(ackId, { content: liveContent.trim() }).catch(() => {});
      }
    }

    function describeCommand(cmd: string): string | null {
      const c = cmd.replace(/\s+/g, " ").trim();
      // Skip noise
      if (/^source\s|^export\s|^cd\s|^echo\s/.test(c)) return null;
      // Board commands
      if (/board project create/.test(c)) {
        const name = c.match(/--name\s+"?([^"]+)"?/)?.[1] ?? c.match(/--name\s+(\S+)/)?.[1];
        const repo = c.match(/--repo\s+(\S+)/)?.[1];
        if (repo) return `Setting up project **${name}** — cloning repo…`;
        return `Creating project **${name}**…`;
      }
      if (/board create/.test(c)) {
        const title = c.match(/--title\s+"([^"]+)"/)?.[1] ?? c.match(/--title\s+(\S+)/)?.[1];
        const parent = /--parent-id/.test(c) ? "child card" : /--project-id/.test(c) ? "card" : "card";
        return title ? `Creating ${parent}: **${title}**` : `Creating card…`;
      }
      if (/board move/.test(c)) {
        const state = c.match(/board move\s+\S+\s+(\S+)/)?.[1];
        return state ? `Moving card to **${state}**…` : `Updating card status…`;
      }
      if (/board update/.test(c)) return `Updating card…`;
      if (/board archive/.test(c)) return `Archiving card…`;
      if (/board settings set/.test(c)) {
        const key = c.match(/board settings set\s+(\S+)/)?.[1];
        return `Saving setting: **${key}**…`;
      }
      if (/board settings get/.test(c)) return `Checking settings…`;
      if (/board project list|board search/.test(c)) return `Looking up existing work…`;
      if (/board show/.test(c)) return `Reading card details…`;
      // Git
      if (/git clone/.test(c)) {
        const url = c.match(/git clone\s+(\S+)/)?.[1];
        return url ? `Cloning \`${url.split("/").slice(-1)[0]}\`…` : `Cloning repository…`;
      }
      if (/git config/.test(c)) return `Configuring git…`;
      if (/gh auth/.test(c)) return `Authenticating with GitHub…`;
      // Generic
      return null;
    }

    function onEvent(ev: { type?: string; message?: { content?: unknown[] } }) {
      if (ev.type !== "assistant" || !ev.message?.content) return;
      for (const block of ev.message.content) {
        const b = block as { type?: string; text?: string; name?: string; input?: Record<string, unknown> };
        if (b.type === "text" && b.text) {
          liveContent += b.text;
          flushLive();
        } else if (b.type === "tool_use" && b.name) {
          let line: string | null = null;
          if (b.name === "Bash" && b.input?.command) {
            const cmd = String(b.input.command);
            // Try each line of multi-line commands
            const desc = cmd.split(/&&|\n/).map(s => describeCommand(s.trim())).find(Boolean);
            if (desc) line = `\n${desc}`;
          } else if (b.name === "Read" && b.input?.file_path) {
            const parts = String(b.input.file_path).split("/");
            line = `\n_Reading ${parts.slice(-2).join("/")}_`;
          } else if (b.name === "Grep" && b.input?.pattern) {
            line = `\n_Searching codebase…_`;
          } else if (b.name === "Write" && b.input?.file_path) {
            const parts = String(b.input.file_path).split("/");
            line = `\n_Writing ${parts.slice(-1)[0]}_`;
          }
          if (line && !liveContent.trimEnd().endsWith(line.trim())) {
            liveContent += line;
            flushLive();
          }
        }
      }
    }

    const result = await invokeClaude(REPO_ROOT, prompt, {
      systemPrompt: CHAT_SYSTEM_PROMPT,
      model: CHAT_MODEL,
      onEvent,
    });

    // Extract everything after the last CHAT_RESPONSE: marker
    const responseText = result.result ?? "";
    const marker = "CHAT_RESPONSE:";
    const markerIdx = responseText.lastIndexOf(marker);
    const response = markerIdx >= 0
      ? responseText.slice(markerIdx + marker.length).trim()
      : responseText.trim();

    // Replace the live-streaming ack with the final clean response
    if (ackId) {
      await patchChatMessage(ackId, { content: response, status: "done" });
    } else {
      await postChatMessage(response);
    }

    // Mark user message done
    await patchChatMessage(msg.id, { status: "done" });
  } catch (err) {
    console.error("[dispatch] chat error:", err);
    if (ackId) await patchChatMessage(ackId, { content: "Error processing your message. Please try again.", status: "done" });
    await patchChatMessage(msg.id, { status: "error" });
  } finally {
    chatInFlightCount--;
  }
}

async function processChatCycle(): Promise<void> {
  if (chatInFlightCount >= MAX_CHAT_CONCURRENCY) return;
  try {
    const available = MAX_CHAT_CONCURRENCY - chatInFlightCount;
    const res = await fetch(`${BOARD_URL}/api/chat?status=pending&limit=${available}`);
    if (!res.ok) return;
    const messages: ChatMessage[] = await res.json();
    for (const msg of messages) {
      chatInFlightCount++;
      processChat(msg); // fire-and-forget — each message gets its own ack immediately
    }
  } catch { /* board may not be up yet */ }
}

// ── Main dispatch loop ───────────────────────────────────────────────────────

async function dispatchCycle(): Promise<void> {
  await cleanStaleWorktrees();

  const allActive = await fetchActiveCards();
  const cards = pickCards(allActive);

  if (inFlight.size >= MAX_CARD_CONCURRENCY_GLOBAL) return;

  const toStart: Card[] = [];
  for (const card of cards) {
    if (inFlight.has(card.id)) continue;
    if (inFlight.size + toStart.length >= MAX_CARD_CONCURRENCY_GLOBAL) break;
    const projectKey = card.projectId ?? null;
    if (inFlightForProject(projectKey) + toStart.filter(c => (c.projectId ?? null) === projectKey).length >= MAX_CARD_CONCURRENCY_PER_PROJECT) continue;
    toStart.push(card);
  }
  for (const card of toStart) {
    runCard(card); // intentionally fire-and-forget — tracked via inFlight
  }
}

async function main(): Promise<void> {
  console.log(`[dispatch] starting — polling ${BOARD_URL} every ${POLL_INTERVAL_MS / 1000}s (cards: global max ${MAX_CARD_CONCURRENCY_GLOBAL}, per-project max ${MAX_CARD_CONCURRENCY_PER_PROJECT}; chat: independent, max ${MAX_CHAT_CONCURRENCY} concurrent)`);

  // Chat runs on its own fast loop — 500ms for snappy ack response
  (async () => {
    while (true) {
      try { await processChatCycle(); } catch (err) { console.error("[dispatch] chat error:", err); }
      await Bun.sleep(500);
    }
  })();

  // Card dispatch on the normal 5s interval
  while (true) {
    try { await dispatchCycle(); } catch (err) { console.error("[dispatch] cycle error:", err); }
    await Bun.sleep(POLL_INTERVAL_MS);
  }
}

if (import.meta.main) {
  main();
}
