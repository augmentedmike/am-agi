#!/usr/bin/env bash
# ship-hook-project — ship hook for external project cards (non-AM repos)
# Usage: ship-hook-project <workDir> <cardId> <commitMsg> [<version>] [<repoDir>] [<branch>]
#
# Architecture:
#   - WORK_DIR is a worktree of the EXTERNAL project repo (e.g. helloam-www),
#     checked out at a branch named after the card ID.
#   - REPO_DIR is the main working copy of that external repo (workspaces/helloam-www).
#   - Commits are in WORK_DIR's branch — squash them and push to origin/$BRANCH.
#   - This hook does NOT touch am-agi/dev — external project cards don't ship am-agi code.
set -euo pipefail

WORK_DIR="$1"
SLUG="$2"
MSG="$3"
VERSION="${4:-}"
REPO_DIR="${5:-}"
BRANCH="${6:-main}"

REPO="$(cd "$(dirname "$0")/.." && pwd)"
LOG="/tmp/am-ship-hook.log"
BOARD_URL="http://localhost:4220"

SLUG_LOCK="/tmp/am-ship-hook-${SLUG}.lock"
if ! mkdir "$SLUG_LOCK" 2>/dev/null; then
  echo "" >> "$LOG"
  echo "=== ship-hook-project SKIP $(date) slug=$SLUG — already running ===" >> "$LOG"
  exit 0
fi

exec >> "$LOG" 2>&1
trap 'rmdir "$SLUG_LOCK" 2>/dev/null || true' EXIT

echo ""
echo "=== ship-hook-project $(date) slug=$SLUG branch=$BRANCH ==="

# ── Inject vault token into remote URL ───────────────────────────────────────
inject_github_token() {
  local repo_path="$1"
  local token
  token=$("$REPO/bin/vault" get github_token 2>/dev/null || true)
  [ -z "$token" ] && return
  local remote_url
  remote_url=$(git -C "$repo_path" remote get-url origin 2>/dev/null || true)
  if echo "$remote_url" | grep -q "github.com"; then
    local authed_url
    authed_url=$(echo "$remote_url" | sed "s|https://[^@]*@|https://|; s|https://|https://${token}@|")
    git -C "$repo_path" remote set-url origin "$authed_url"
    echo "ship-hook-project: injected token into $repo_path"
  fi
}

fail_to_review() {
  local reason="$1"
  echo "ship-hook-project FAILED: $reason"
  curl -s -X POST "$BOARD_URL/api/cards/$SLUG/move" \
    -H 'Content-Type: application/json' \
    -d "{\"state\":\"in-progress\",\"note\":\"ship-hook failed: $reason — resolve and re-ship\"}" \
    >> "$LOG" 2>&1 || true
}

# ── Save workspace docs ───────────────────────────────────────────────────────
DOCS_DIR="$REPO/workspaces/cards/$SLUG"
mkdir -p "$DOCS_DIR"
for f in research.md criteria.md todo.md work.md; do
  [ -f "$WORK_DIR/$f" ] && cp "$WORK_DIR/$f" "$DOCS_DIR/$f"
done

# ── Step 1: Squash WORK_DIR commits and push to external project origin/$BRANCH ──
# WORK_DIR is a worktree of the external repo. Squash all iter commits into one
# clean commit on top of origin/$BRANCH, then push.
if [ ! -d "$WORK_DIR" ]; then
  echo "ship-hook-project: WORK_DIR $WORK_DIR does not exist — nothing to ship"
  exit 0
fi

cd "$WORK_DIR"
git checkout -- . 2>/dev/null || true
git clean -fd -- research.md criteria.md todo.md work.md user-notes.md iter/ bunfig.toml bun.lock 2>/dev/null || true
inject_github_token "$WORK_DIR"
git fetch origin

MERGE_BASE=$(git merge-base HEAD "origin/$BRANCH" 2>/dev/null || git rev-list --max-parents=0 HEAD)
git reset "$MERGE_BASE"
git add -A -- ':!research.md' ':!criteria.md' ':!todo.md' ':!work.md' ':!user-notes.md' ':!iter/' ':!bunfig.toml' ':!bun.lock' || true

if ! git diff --cached --quiet; then
  git commit -m "$MSG"
else
  echo "ship-hook-project: no changes to commit in WORK_DIR"
fi

# Rebase onto latest branch tip
if ! git rebase "origin/$BRANCH"; then
  git rebase --abort 2>/dev/null || true
  fail_to_review "rebase onto origin/$BRANCH failed — conflict needs agent resolution"
  exit 1
fi

# Push squashed commit to origin/$BRANCH
inject_github_token "$WORK_DIR"
if ! git push origin "HEAD:$BRANCH"; then
  fail_to_review "git push to origin/$BRANCH failed"
  exit 1
fi
echo "ship-hook-project: pushed to origin/$BRANCH"

# ── Step 2: Clean up external project worktree ────────────────────────────────
EXPANDED_REPO_DIR="${REPO_DIR/#\~/$HOME}"
if [ -d "$EXPANDED_REPO_DIR" ] && ([ -d "$EXPANDED_REPO_DIR/.git" ] || [ -f "$EXPANDED_REPO_DIR/.git" ]); then
  git -C "$EXPANDED_REPO_DIR" worktree remove --force "$WORK_DIR" 2>/dev/null || true
  git -C "$EXPANDED_REPO_DIR" branch -D "$SLUG" 2>/dev/null || true
  git -C "$EXPANDED_REPO_DIR" worktree prune 2>/dev/null || true
  echo "ship-hook-project: cleaned up worktree $WORK_DIR"
else
  # Fallback: remove as am-agi worktree if REPO_DIR not found
  cd "$REPO"
  git worktree remove --force "$WORK_DIR" 2>/dev/null || true
  git branch -D "$SLUG" 2>/dev/null || true
fi

echo "=== ship-hook-project done ==="
