#!/usr/bin/env bash
# email-sync — manage email sync accounts and trigger syncs via the board API
#
# Usage:
#   email-sync list-accounts
#   email-sync add-account --provider <provider> --account <account-email>
#   email-sync remove-account <id>
#   email-sync sync [--account <id>]

set -euo pipefail

BOARD_URL="${BOARD_URL:-http://localhost:4220}"

# ── Helpers ───────────────────────────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }

api_get() {
  local path="$1"
  curl -sf "${BOARD_URL}${path}" \
    -H "Content-Type: application/json"
}

api_post() {
  local path="$1"
  local body="$2"
  curl -sf -X POST "${BOARD_URL}${path}" \
    -H "Content-Type: application/json" \
    -d "$body"
}

api_delete() {
  local path="$1"
  curl -sf -X DELETE "${BOARD_URL}${path}" \
    -H "Content-Type: application/json" \
    -o /dev/null -w "%{http_code}"
}

# ── Subcommands ───────────────────────────────────────────────────────────────

cmd_list_accounts() {
  local result
  result="$(api_get "/api/email-syncs" 2>/dev/null)" \
    || die "could not reach board API at $BOARD_URL"
  echo "$result"
}

cmd_add_account() {
  local provider="" account_email=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider) provider="$2"; shift 2 ;;
      --account)  account_email="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  [[ -z "$provider" ]]      && die "--provider is required"
  [[ -z "$account_email" ]] && die "--account is required"

  local body
  body="$(printf '{"provider":"%s","accountEmail":"%s"}' "$provider" "$account_email")"
  local result
  result="$(api_post "/api/email-syncs" "$body" 2>/dev/null)" \
    || die "could not reach board API at $BOARD_URL"
  echo "$result"
}

cmd_remove_account() {
  local id="${1:-}"
  [[ -z "$id" ]] && die "usage: email-sync remove-account <id>"
  local status
  status="$(api_delete "/api/email-syncs/${id}" 2>/dev/null)" \
    || die "could not reach board API at $BOARD_URL"
  if [[ "$status" == "204" ]]; then
    echo "removed $id"
  else
    die "unexpected status $status removing sync account $id"
  fi
}

cmd_sync() {
  local id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --account) id="$2"; shift 2 ;;
      *) id="$1"; shift ;;
    esac
  done
  local path
  if [[ -n "$id" ]]; then
    path="/api/email-syncs/${id}/sync"
  else
    path="/api/email-syncs/sync"
  fi
  local result
  result="$(api_post "$path" '{}' 2>/dev/null)" \
    || die "could not reach board API at $BOARD_URL"
  echo "$result"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift || true

case "$CMD" in
  list-accounts)   cmd_list_accounts "$@" ;;
  add-account)     cmd_add_account "$@" ;;
  remove-account)  cmd_remove_account "$@" ;;
  sync)            cmd_sync "$@" ;;
  help|--help|-h)
    cat <<'HELP'
email-sync — manage email sync accounts and trigger syncs

  email-sync list-accounts
      List all registered sync accounts.

  email-sync add-account --provider <provider> --account <account-email>
      Register a new email sync account.
      --provider   Email provider name (e.g. gmail, outlook)
      --account    Account email address

  email-sync remove-account <id>
      Remove a registered sync account by ID.

  email-sync sync [--account <id>]
      Trigger a sync. If --account is omitted, syncs all accounts.

Environment:
  BOARD_URL   Board API base URL (default: http://localhost:4220)
HELP
    ;;
  *) echo "unknown command: $CMD — run 'email-sync help'" >&2; exit 1 ;;
esac
