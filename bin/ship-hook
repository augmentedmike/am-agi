#!/usr/bin/env bash
# ship-hook — run after an AM Board card ships
# Usage: ship-hook <workDir> <cardId> <commitMsg> [<version>]
# Called by the move route's ship queue — one at a time, never concurrent.
set -euo pipefail

WORK_DIR="$1"
SLUG="$2"      # == card UUID == worktrees/<slug>
MSG="$3"
VERSION="${4:-}"
REPO_DIR="${5:-}"      # external project repo dir — push here after ship if set
PROJECT_BRANCH="${6:-main}"  # default branch of external project repo

REPO="$(cd "$(dirname "$0")/.." && pwd)"
LOG="/tmp/am-ship-hook.log"
BOARD_URL="http://localhost:4220"

# Per-slug lock: belt-and-suspenders guard against duplicate spawns.
SLUG_LOCK="/tmp/am-ship-hook-${SLUG}.lock"
if ! mkdir "$SLUG_LOCK" 2>/dev/null; then
  echo "" >> "$LOG"
  echo "=== ship-hook SKIP $(date) slug=$SLUG — already running ===" >> "$LOG"
  exit 0
fi

exec >> "$LOG" 2>&1
trap 'rmdir "$SLUG_LOCK" 2>/dev/null || true; rmdir "$GLOBAL_LOCK" 2>/dev/null || true' EXIT

# Global serialization lock — only one ship-hook runs at a time across all processes/restarts.
# Uses a spin-wait with backoff so queued hooks eventually run rather than failing.
GLOBAL_LOCK="/tmp/am-ship-hook-global.lock"
MAX_WAIT=300  # seconds
WAITED=0
SLEEP=2
until mkdir "$GLOBAL_LOCK" 2>/dev/null; do
  if [ "$WAITED" -ge "$MAX_WAIT" ]; then
    fail_to_review "global ship lock held for >${MAX_WAIT}s — possible stale lock, retrying"
    # Force-remove stale lock and try once more
    rmdir "$GLOBAL_LOCK" 2>/dev/null || true
    mkdir "$GLOBAL_LOCK" || { fail_to_review "could not acquire global ship lock"; exit 1; }
    break
  fi
  echo "=== ship-hook WAITING for global lock (${WAITED}s elapsed) slug=$SLUG ===" >> "$LOG"
  sleep "$SLEEP"
  WAITED=$((WAITED + SLEEP))
  SLEEP=$((SLEEP < 10 ? SLEEP + 1 : 10))  # ramp up to 10s intervals
done
echo "=== acquired global ship lock after ${WAITED}s ===" >> "$LOG"

# ── Inject vault token into a repo's remote URL ───────────────────────────────
inject_github_token() {
  local repo_path="$1"
  local token
  token=$("$REPO/bin/vault" get github_token 2>/dev/null || true)
  if [ -z "$token" ]; then
    echo "ship-hook: no github_token in vault — push may fail if token missing from remote"
    return
  fi
  local remote_url
  remote_url=$(git -C "$repo_path" remote get-url origin 2>/dev/null || true)
  if echo "$remote_url" | grep -q "github.com"; then
    local authed_url
    authed_url=$(echo "$remote_url" | sed "s|https://[^@]*@|https://|; s|https://|https://${token}@|")
    git -C "$repo_path" remote set-url origin "$authed_url"
    echo "ship-hook: injected vault token into remote URL"
  fi
}

# On any failure, move card back to in-review so the agent can resolve it.
# Closes the feedback loop — no more silent failures left in "shipped" state.
fail_to_review() {
  local reason="$1"
  echo "ship-hook FAILED: $reason"
  # shipped → in-review is invalid; shipped → in-progress is the correct rollback
  curl -s -X POST "$BOARD_URL/api/cards/$SLUG/move" \
    -H 'Content-Type: application/json' \
    -d "{\"state\":\"in-progress\",\"note\":\"ship-hook failed: $reason — resolve and re-ship\"}" \
    >> "$LOG" 2>&1 || true
}

echo ""
echo "=== ship-hook $(date) slug=$SLUG version=$VERSION ==="

# ── Save workspace docs before any git ops ───────────────────────────────────
DOCS_DIR="$REPO/workspaces/cards/$SLUG"
mkdir -p "$DOCS_DIR"
for f in research.md criteria.md todo.md work.md; do
  [ -f "$WORK_DIR/$f" ] && cp "$WORK_DIR/$f" "$DOCS_DIR/$f"
done

# ── Step 1: Rebase worktree onto latest dev ───────────────────────────────────
# This is the key step that all previous approaches skipped.
# Squashing off a stale base is the root cause of every patch-apply failure.
# After this, the worktree tip is on top of current dev — cherry-pick is clean.
cd "$WORK_DIR"
# Discard unstaged changes to excluded files (research.md, todo.md, etc.) so
# rebase doesn't abort. We already saved them to workspace docs above.
git checkout -- . 2>/dev/null || true
git clean -fd -- research.md criteria.md todo.md work.md user-notes.md 2>/dev/null || true
git fetch origin
# Detect base branch: use origin/dev if it exists (am repo), else origin/main (external projects)
if git rev-parse --verify origin/dev >/dev/null 2>&1; then
  WORK_BASE="origin/dev"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  WORK_BASE="origin/main"
  echo "ship-hook: origin/dev not found — rebasing onto origin/main"
else
  fail_to_review "no origin/dev or origin/main found — cannot determine rebase target"
  exit 1
fi
if ! git rebase "$WORK_BASE"; then
  git rebase --abort 2>/dev/null || true
  fail_to_review "rebase onto $WORK_BASE failed — conflict needs agent resolution"
  exit 1
fi

# ── Step 2: Squash all iter commits into one ──────────────────────────────────
MERGE_BASE=$(git merge-base HEAD "$WORK_BASE")
git reset "$MERGE_BASE"
git add -A -- ':!research.md' ':!criteria.md' ':!todo.md' ':!work.md' ':!user-notes.md' ':!iter/' ':!apps/' ':!.next/' || true

SQUASH_SHA=""
if ! git diff --cached --quiet; then
  git commit -m "$MSG"
  SQUASH_SHA=$(git rev-parse HEAD)
else
  echo "ship-hook: no code changes vs dev — nothing to commit"
fi

# ── Step 3: Cherry-pick the squashed commit onto dev ─────────────────────────
# cherry-pick uses git's native merge engine against the right base (origin/dev).
# After step 1, SQUASH_SHA's parent IS origin/dev, so this is almost always clean.
# If it still conflicts (same lines changed), fail back to in-review.
cd "$REPO"
git fetch origin
git checkout dev
git reset --hard origin/dev

if [ -n "$SQUASH_SHA" ]; then
  if ! git cherry-pick --no-commit "$SQUASH_SHA"; then
    git cherry-pick --abort 2>/dev/null || git reset HEAD 2>/dev/null || true
    git checkout -- . 2>/dev/null || true
    fail_to_review "cherry-pick conflict — same lines changed as another card, needs agent resolution"
    exit 1
  fi
  git commit -m "$MSG" || echo "ship-hook: nothing to commit (cherry-pick was empty)"
fi

# ── Step 4: Version bump ──────────────────────────────────────────────────────
# Only bump if card version is strictly greater than current — never downgrade.
if [ -n "$VERSION" ]; then
  V="${VERSION#v}"
  PKG="$REPO/board/package.json"
  CURRENT=$(node -e "console.log(require('$PKG').version)")
  IS_NEWER=$(node -e "
    const parse = v => v.split('.').map(Number);
    const [ca,cb,cc] = parse('$CURRENT');
    const [va,vb,vc] = parse('$V');
    const newer = va>ca || (va===ca && vb>cb) || (va===ca && vb===cb && vc>cc);
    console.log(newer ? 'yes' : 'no');
  ")
  if [ "\$IS_NEWER" = "yes" ]; then
    node -e "const fs=require('fs');const p=JSON.parse(fs.readFileSync('$PKG'));p.version='$V';fs.writeFileSync('$PKG',JSON.stringify(p,null,2)+'\n')"
    # Also sync DB so new cards get the right stamp
    DB="$REPO/board/board.db"
    [ -f "$DB" ] && sqlite3 "$DB" "UPDATE projects SET current_version='$V', updated_at=datetime('now') WHERE versioned=1 AND (current_version IS NULL OR current_version='$CURRENT' OR current_version='v$CURRENT');" || true
    git add "$PKG"
    git commit -m "bump: v$V"
    git tag "v$V" 2>/dev/null || true
  else
    echo "ship-hook: skipping version bump — card version $V is not newer than current $CURRENT"
  fi
fi

# ── Step 5: Push ──────────────────────────────────────────────────────────────
inject_github_token "$REPO"
git push origin dev || echo "ship-hook: WARNING — push origin dev failed (token expired?)"
[ -n "$VERSION" ] && git push origin "v${VERSION#v}" 2>/dev/null || true

# ── Step 5b: Sync main ────────────────────────────────────────────────────────
# After each ship, try to fast-forward main to dev. If fast-forward is not
# possible (diverged histories), create a PR from a cherry-pick branch so the
# changes land on main without conflicts.
sync_main() {
  local token
  token=$("$REPO/bin/vault" get github_token 2>/dev/null || true)
  [ -z "$token" ] && { echo "ship-hook: no github_token — skipping main sync"; return; }

  git fetch origin
  local main_sha dev_sha
  main_sha=$(git rev-parse origin/main 2>/dev/null || true)
  dev_sha=$(git rev-parse origin/dev 2>/dev/null || true)
  [ "$main_sha" = "$dev_sha" ] && { echo "ship-hook: main already at dev, nothing to sync"; return; }

  # Try fast-forward first
  local ff_possible
  ff_possible=$(git merge-base --is-ancestor "$main_sha" "$dev_sha" 2>/dev/null && echo yes || echo no)
  if [ "$ff_possible" = "yes" ]; then
    git push origin "origin/dev:main" && echo "ship-hook: fast-forwarded main to dev" && return
  fi

  # Diverged: cherry-pick squashed commit onto a branch from main and PR it
  [ -z "$SQUASH_SHA" ] && { echo "ship-hook: no squash SHA, skipping main PR"; return; }
  local pr_branch="main-sync-${SLUG}"
  git checkout -B "$pr_branch" origin/main
  if git cherry-pick --no-commit "$SQUASH_SHA" 2>/dev/null; then
    if ! git diff --cached --quiet; then
      git commit -m "$MSG"
      git push origin "$pr_branch"
      export GITHUB_TOKEN="$token"
      local pr_url
      pr_url=$(gh pr create --base main --head "$pr_branch" \
        --title "$MSG" \
        --body "Auto-synced from ship hook after card $SLUG shipped." \
        --repo augmentedmike/am-agi 2>/dev/null || true)
      if [ -n "$pr_url" ]; then
        local pr_num
        pr_num=$(echo "$pr_url" | grep -o '[0-9]*$')
        gh pr merge "$pr_num" --merge --repo augmentedmike/am-agi 2>/dev/null && \
          echo "ship-hook: merged PR $pr_num to main" || \
          echo "ship-hook: created PR $pr_num to main (merge pending)"
      fi
    else
      echo "ship-hook: cherry-pick was empty — no main PR needed"
      git cherry-pick --abort 2>/dev/null || true
    fi
  else
    git cherry-pick --abort 2>/dev/null || true
    echo "ship-hook: cherry-pick conflict — skipping auto main PR for $SLUG"
  fi
  git checkout dev 2>/dev/null || true
  git branch -D "$pr_branch" 2>/dev/null || true
}
sync_main

# ── Step 6: Deploy ────────────────────────────────────────────────────────────
# board-deploy has its own lock+waiter — no need to wait here.
"$REPO/bin/board-deploy"

# ── Step 7: Clean up worktree ─────────────────────────────────────────────────
git worktree remove --force "$WORK_DIR" 2>/dev/null || true
git branch -D "$SLUG" 2>/dev/null || true

# ── Step 8: Push external project repo ───────────────────────────────────────
if [ -n "$REPO_DIR" ]; then
  EXPANDED_REPO_DIR="${REPO_DIR/#\~/$HOME}"
  echo "ship-hook: pushing external project repo $EXPANDED_REPO_DIR"
  if [ -d "$EXPANDED_REPO_DIR" ]; then
    inject_github_token "$EXPANDED_REPO_DIR"
    git -C "$EXPANDED_REPO_DIR" push origin "$PROJECT_BRANCH" 2>&1 || echo "ship-hook: git push failed for $EXPANDED_REPO_DIR"
  else
    echo "ship-hook: repoDir $EXPANDED_REPO_DIR does not exist — skipping push"
  fi
fi

echo "=== ship-hook done ==="
