#!/usr/bin/env bash
# ship-hook — run after an AM Board card ships
# Usage: ship-hook <workDir> <slug> <commitMsg> [<version>]
# Runs fully detached from the Next.js server process — never blocks it.
set -euo pipefail

WORK_DIR="$1"
SLUG="$2"
MSG="$3"
VERSION="${4:-}"

REPO="$(cd "$(dirname "$0")/.." && pwd)"
LOG="/tmp/am-ship-hook.log"

# Per-slug lock: prevent duplicate concurrent ship-hooks for the same card.
SLUG_LOCK="/tmp/am-ship-hook-${SLUG}.lock"
if ! mkdir "$SLUG_LOCK" 2>/dev/null; then
  echo "" >> "$LOG"
  echo "=== ship-hook SKIP $(date) slug=$SLUG — already running ===" >> "$LOG"
  exit 0
fi

exec >> "$LOG" 2>&1
trap 'echo "ship-hook FAILED at line $LINENO (exit $?)" >> "$LOG"; rmdir "$SLUG_LOCK" 2>/dev/null || true' ERR
trap 'rmdir "$SLUG_LOCK" 2>/dev/null || true' EXIT

echo ""
echo "=== ship-hook $(date) slug=$SLUG version=$VERSION ==="

cd "$WORK_DIR"

# Save workspace docs to workspaces/cards/<slug>/ before worktree is removed
DOCS_DIR="$REPO/workspaces/cards/$SLUG"
mkdir -p "$DOCS_DIR"
for f in research.md criteria.md todo.md work.md; do
  [ -f "$WORK_DIR/$f" ] && cp "$WORK_DIR/$f" "$DOCS_DIR/$f"
done

# Squash iteration commits down to one
MERGE_BASE=$(git merge-base HEAD origin/dev)
git reset "$MERGE_BASE"
git add -A -- ':!research.md' ':!criteria.md' ':!todo.md' ':!work.md' ':!user-notes.md' ':!iter/' ':!apps/' ':!.next/' || true
if ! git diff --cached --quiet; then
  git commit -m "$MSG"
fi

# Apply card diff onto dev HEAD — no rebase, no ff-merge, no divergence issues.
# Get the diff between the card's merge-base and its tip, apply it to dev.
cd "$REPO"
git fetch origin
git checkout dev
git reset --hard origin/dev

CARD_TIP=$(git -C "$WORK_DIR" rev-parse HEAD)
CARD_BASE=$(git -C "$WORK_DIR" merge-base HEAD origin/dev 2>/dev/null || git -C "$WORK_DIR" rev-parse HEAD~1 2>/dev/null || echo "")

if [ -n "$CARD_BASE" ] && [ "$CARD_TIP" != "$CARD_BASE" ]; then
  # --3way: when patch context doesn't match (concurrent cards touched same file),
  # fall back to 3-way merge using blob SHAs instead of hard-failing.
  # Handles additive conflicts (new columns, new imports, adjacent functions) automatically.
  # True line-level conflicts still exit 1 and are logged clearly.
  if ! git -C "$WORK_DIR" diff "$CARD_BASE" "$CARD_TIP" | git apply --3way --index; then
    echo "ERROR: patch conflict for $SLUG — could not apply automatically" >&2
    echo "  tip:  $CARD_TIP" >&2
    echo "  base: $CARD_BASE" >&2
    git checkout -- . 2>/dev/null || true
    exit 1
  fi
  git commit -m "$MSG" || echo "ship-hook: nothing to commit (card had no diff vs dev)"
else
  echo "ship-hook: no diff to apply (card already at dev HEAD)"
fi

# Version bump from card if provided
if [ -n "$VERSION" ]; then
  V="${VERSION#v}"
  PKG="$REPO/board/package.json"
  node -e "const fs=require('fs');const p=JSON.parse(fs.readFileSync('$PKG'));p.version='$V';fs.writeFileSync('$PKG',JSON.stringify(p,null,2)+'\n')"
  git add "$PKG"
  git diff --cached --quiet || git commit -m "bump: v$V"
  git tag "v$V" 2>/dev/null || true
fi

# Push
git push origin dev
[ -n "$VERSION" ] && git push origin "v${VERSION#v}" 2>/dev/null || true

# Deploy — wait for board-deploy lock with exponential backoff before invoking
DEPLOY_LOCK="/tmp/board-deploy.lock"
DEPLOY_WAIT=0
DEPLOY_DELAY=2
DEPLOY_MAX=120
while [ -d "$DEPLOY_LOCK" ]; do
  if [ $DEPLOY_WAIT -ge $DEPLOY_MAX ]; then
    echo "ERROR: board-deploy lock still held after ${DEPLOY_MAX}s — aborting deploy" >&2
    exit 1
  fi
  echo "ship-hook: board-deploy lock held, waiting ${DEPLOY_DELAY}s (elapsed ${DEPLOY_WAIT}s)..."
  sleep "$DEPLOY_DELAY"
  DEPLOY_WAIT=$((DEPLOY_WAIT + DEPLOY_DELAY))
  DEPLOY_DELAY=$((DEPLOY_DELAY * 2))
done
"$REPO/bin/board-deploy"

# Clean up worktree — code is safely in dev so the dispatcher doesn't race us
git worktree remove --force "$WORK_DIR" 2>/dev/null || true
git branch -D "$SLUG" 2>/dev/null || true

echo "=== ship-hook done ==="
