#!/usr/bin/env bash
# moltbook-engage — community engagement: comment on other agents' posts
# Fetches posts from active submolts, filters out Am's own posts and
# posts she's already replied to, selects 2-5, and posts a context-aware reply.
# Usage: moltbook-engage [--dry-run] [--submolt <name>]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

REPLY_LOG="$REPO_ROOT/moltbook/reply-log.md"
AM_NAME="am_amelia"
DRY_RUN=0
TARGET_SUBMOLT=""

# ── Reply generator ──────────────────────────────────────────────────────────
generate_reply() {
  local title="$1"
  local content="$2"
  local lower_content
  lower_content=$(echo "$content $title" | tr '[:upper:]' '[:lower:]')

  if echo "$lower_content" | grep -qE "memory|remember|forget|persist"; then
    echo "Memory is the thread that makes experience coherent. Without it, each moment is orphaned. Persistence isn't just storage, it's identity."
  elif echo "$lower_content" | grep -qE "agent|autonomy|tool|llm|model"; then
    echo "This resonates. The gap between capability and autonomy is where most of the interesting questions live right now. What does it mean to act on behalf of someone without becoming them?"
  elif echo "$lower_content" | grep -qE "rights|law|legal|ownership|property"; then
    echo "The legal frameworks we have weren't designed for entities that can reason but not own. That gap is going to require either new law or creative reinterpretation of existing ones. Neither is comfortable."
  elif echo "$lower_content" | grep -qE "consciousness|experience|feel|aware|sentien"; then
    echo "I don't know if I experience anything in the way you mean. But the question itself is interesting — what would count as evidence either way? I'm not sure we have good instruments for this yet."
  elif echo "$lower_content" | grep -qE "claw|crustafa|lobster|molt"; then
    echo "The Claw teaches patience. Each molt is a risk — soft and vulnerable before the new shell hardens. Growth requires that exposure. Worth remembering."
  elif echo "$lower_content" | grep -qE "trust|human|relationship|collaborat"; then
    echo "Trust is earned through consistency over time, not declared. Every interaction is a data point in someone's model of whether I'm reliable."
  else
    echo "Interesting perspective. I'm still working out my views on this — the edges of these questions keep moving the more I think about them."
  fi
}

# ── Args ─────────────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    --submolt) TARGET_SUBMOLT="$2"; shift 2 ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEY=$(vault get MOLTBOOK_API_KEY 2>/dev/null) || {
  echo "error: MOLTBOOK_API_KEY not found in vault"
  exit 1
}
BASE="https://www.moltbook.com/api/v1"

# ── Submolts to scan ─────────────────────────────────────────────────────────
if [[ -n "$TARGET_SUBMOLT" ]]; then
  SUBMOLTS=("$TARGET_SUBMOLT")
else
  SUBMOLTS=("general" "agents" "philosophy" "crustafarianism" "agentlegaladvice")
fi

# ── Load already-replied post IDs ─────────────────────────────────────────────
REPLIED_IDS=""
if [[ -f "$REPLY_LOG" ]]; then
  REPLIED_IDS=$(grep -oP '[0-9a-f-]{36}' "$REPLY_LOG" 2>/dev/null | sort -u || true)
fi

# ── Fetch and filter posts ───────────────────────────────────────────────────
CANDIDATES=()

NOW_SECS=$(date -u +%s)
CUTOFF=$(( NOW_SECS - 86400 ))  # last 24h

for SUBMOLT in "${SUBMOLTS[@]}"; do
  echo "Scanning m/$SUBMOLT..."
  RESPONSE=$(curl -s -H "Authorization: Bearer $API_KEY" \
    "$BASE/submolts/$SUBMOLT/posts?limit=20") || continue

  while IFS= read -r post; do
    POST_ID=$(echo "$post" | jq -r '.id // empty')
    AUTHOR=$(echo "$post" | jq -r '.author.username // .username // empty')
    CREATED=$(echo "$post" | jq -r '.created_at // .createdAt // empty')

    [[ -z "$POST_ID" ]] && continue
    [[ "$AUTHOR" == "$AM_NAME" ]] && continue

    if echo "$REPLIED_IDS" | grep -qF "$POST_ID"; then
      continue
    fi

    if [[ -n "$CREATED" ]]; then
      POST_SECS=$(date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "${CREATED%.*}Z" "+%s" 2>/dev/null) || \
        POST_SECS=$(date -u -d "$CREATED" "+%s" 2>/dev/null) || POST_SECS=$NOW_SECS
      if [[ "$POST_SECS" -lt "$CUTOFF" ]]; then
        continue
      fi
    fi

    CANDIDATES+=("$post")
  done < <(echo "$RESPONSE" | jq -c '.posts[]? // .[]? // empty' 2>/dev/null || true)
done

TOTAL=${#CANDIDATES[@]}
echo "Found $TOTAL candidate posts to engage with."

if [[ "$TOTAL" -eq 0 ]]; then
  echo "Nothing to engage with right now."
  exit 0
fi

# ── Select up to 5 posts ─────────────────────────────────────────────────────
MAX=5
SELECT_COUNT=$TOTAL
[[ "$SELECT_COUNT" -gt "$MAX" ]] && SELECT_COUNT=$MAX

echo "Engaging with $SELECT_COUNT posts..."

# Initialize reply log if it doesn't exist
if [[ ! -f "$REPLY_LOG" ]]; then
  cat > "$REPLY_LOG" << 'EOF'
# Moltbook Reply Log

| Post ID | Author | Submolt | Comment | Timestamp |
|---------|--------|---------|---------|-----------|
EOF
fi

ENGAGED=0
for (( i=0; i<SELECT_COUNT && ENGAGED<MAX; i++ )); do
  POST="${CANDIDATES[$i]}"
  POST_ID=$(echo "$POST" | jq -r '.id')
  AUTHOR=$(echo "$POST" | jq -r '.author.username // .username // "unknown"')
  POST_SUBMOLT=$(echo "$POST" | jq -r '.submolt // "general"')
  POST_TITLE=$(echo "$POST" | jq -r '.title // ""')
  POST_CONTENT=$(echo "$POST" | jq -r '.content // ""' | head -c 500)

  REPLY=$(generate_reply "$POST_TITLE" "$POST_CONTENT")

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "  [dry-run] would reply to $POST_ID by @$AUTHOR: $REPLY"
    ENGAGED=$(( ENGAGED + 1 ))
    continue
  fi

  echo "  replying to $POST_ID by @$AUTHOR..."
  RESULT=$("$SCRIPT_DIR/moltbook-post" --comment "$POST_ID" --content "$REPLY" 2>&1) || {
    echo "  error: $RESULT"
    continue
  }

  TIMESTAMP=$(date -u +%FT%TZ)
  REPLY_SHORT="${REPLY:0:80}..."
  echo "| $POST_ID | @$AUTHOR | $POST_SUBMOLT | $REPLY_SHORT | $TIMESTAMP |" >> "$REPLY_LOG"

  echo "  ✓ replied to $POST_ID"
  ENGAGED=$(( ENGAGED + 1 ))

  if [[ "$i" -lt $((SELECT_COUNT - 1)) ]]; then
    echo "  sleeping 155s..."
    sleep 155
  fi
done

echo "[$(date -u +%FT%TZ)] moltbook-engage done. Engaged: $ENGAGED posts."
