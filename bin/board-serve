#!/usr/bin/env bash
# board-serve — production board server with auto-rebuild on new main commits.
#
# Usage:
#   board-serve            # build once, serve forever on port 4200
#   board-serve --watch    # also poll for new commits on main and hot-swap
#
# Port layout:
#   4200 — production (next start, pre-built, zero compile lag)
#   4202 — dev (next dev --turbopack, hot reload — run with: npm run dev)
#   4201 — ws-server (unchanged)

set -euo pipefail

BOARD_DIR="$(cd "$(dirname "$0")/../board" && pwd)"
PROD_PORT=4200
WATCH=false
SERVE_PID=""
LOG_PREFIX="[board-serve]"

for arg in "$@"; do
  case $arg in
    --watch) WATCH=true ;;
  esac
done

log() { echo "$LOG_PREFIX $*"; }

build() {
  log "building..."
  cd "$BOARD_DIR"
  npm run build
  log "build complete"
}

start_server() {
  cd "$BOARD_DIR"
  npm run start &
  SERVE_PID=$!
  log "production server started (PID $SERVE_PID) → http://localhost:$PROD_PORT"
}

stop_server() {
  if [ -n "$SERVE_PID" ] && kill -0 "$SERVE_PID" 2>/dev/null; then
    log "stopping server (PID $SERVE_PID)"
    kill "$SERVE_PID"
    wait "$SERVE_PID" 2>/dev/null || true
    SERVE_PID=""
  fi
}

# Clean up on exit
trap 'stop_server; exit 0' INT TERM EXIT

# Initial build and serve
build
start_server

if [ "$WATCH" = false ]; then
  log "watching disabled — run with --watch to auto-rebuild on new main commits"
  wait "$SERVE_PID"
  exit 0
fi

# Watch loop: poll for new commits on main every 30s
REPO_ROOT="$(cd "$BOARD_DIR/.." && pwd)"
LAST_COMMIT="$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null || echo '')"

log "watching for new commits on main (polling every 30s)"

while true; do
  sleep 30

  # Fetch quietly — ignore network errors
  git -C "$REPO_ROOT" fetch origin main --quiet 2>/dev/null || true

  LATEST="$(git -C "$REPO_ROOT" rev-parse origin/main 2>/dev/null || echo "$LAST_COMMIT")"

  if [ "$LATEST" != "$LAST_COMMIT" ]; then
    log "new commit detected ($LAST_COMMIT → $LATEST), rebuilding..."
    git -C "$REPO_ROOT" pull --ff-only origin main 2>/dev/null || {
      log "pull failed (non-fast-forward?) — skipping rebuild"
      continue
    }

    # Build into a temp dir first — only swap if build succeeds
    if build; then
      stop_server
      start_server
      LAST_COMMIT="$LATEST"
      log "hot-swapped to new build"
    else
      log "build failed — keeping old build live"
    fi
  fi
done
