#!/usr/bin/env bun
/**
 * board — CLI interface to the Kanban board API.
 *
 * Usage:
 *   board create --title <title> [--priority critical|high|normal|low] [--attach <path>...]
 *   board move <id> <state>
 *   board update <id> [--title <title>] [--priority <priority>] [--log <msg>] [--attach <path>...]
 *   board show <id>
 *   board search [--state <state>] [--priority <priority>] [--text <query>] [--all]
 *   board archive <id> [--reason <msg>]
 *
 * Exit codes: 0 = success, 1 = gate rejection / validation error, 2 = unexpected error
 */

const BOARD_URL = process.env.BOARD_URL ?? "http://localhost:4220";

// ---------------------------------------------------------------------------
// API client
// ---------------------------------------------------------------------------

interface ApiResponse<T = unknown> {
  ok: boolean;
  status: number;
  body: T;
}

async function apiClient<T = unknown>(
  method: string,
  path: string,
  body?: unknown,
): Promise<ApiResponse<T>> {
  const url = `${BOARD_URL}/api${path}`;
  const init: RequestInit = {
    method,
    headers: { "Content-Type": "application/json" },
  };
  if (body !== undefined) {
    init.body = JSON.stringify(body);
  }
  let res: Response;
  try {
    res = await fetch(url, init);
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    process.stderr.write(`board: connection failed — ${msg}\n`);
    process.exit(2);
  }
  let parsed: T;
  try {
    parsed = (await res.json()) as T;
  } catch {
    parsed = null as T;
  }
  return { ok: res.ok, status: res.status, body: parsed };
}

// ---------------------------------------------------------------------------
// Arg parser
// ---------------------------------------------------------------------------

interface ParsedArgs {
  positional: string[];
  flags: Record<string, string | string[]>;
}

function parseArgs(argv: string[]): ParsedArgs {
  const positional: string[] = [];
  const flags: Record<string, string | string[]> = {};
  let i = 0;
  while (i < argv.length) {
    const arg = argv[i];
    if (arg.startsWith("--")) {
      const key = arg.slice(2);
      const val = argv[i + 1];
      if (val === undefined || val.startsWith("--")) {
        flags[key] = "true";
      } else {
        const existing = flags[key];
        if (existing !== undefined) {
          flags[key] = Array.isArray(existing) ? [...existing, val] : [existing, val];
        } else {
          flags[key] = val;
        }
        i++;
      }
    } else {
      positional.push(arg);
    }
    i++;
  }
  return { positional, flags };
}

function flag(args: ParsedArgs, key: string): string | undefined {
  const v = args.flags[key];
  return Array.isArray(v) ? v[v.length - 1] : v;
}

function flagList(args: ParsedArgs, key: string): string[] {
  const v = args.flags[key];
  if (v === undefined) return [];
  return Array.isArray(v) ? v : [v];
}

// ---------------------------------------------------------------------------
// Output helpers
// ---------------------------------------------------------------------------

function out(msg: string): void {
  process.stdout.write(msg + "\n");
}

function die(msg: string, code = 2): never {
  process.stderr.write("board: " + msg + "\n");
  process.exit(code);
}

// ---------------------------------------------------------------------------
// Commands
// ---------------------------------------------------------------------------

async function uploadAttachment(cardId: string, filePath: string): Promise<void> {
  const { readFileSync } = await import("node:fs");
  const { basename } = await import("node:path");
  // Strip any "{uuid}-{timestamp}-" prefix that gets added by the upload server,
  // so that re-attaching an already-uploaded file doesn't double the prefix.
  const raw = basename(filePath);
  const filename = raw.replace(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}-\d+-/, '');
  let data: Buffer;
  try {
    data = readFileSync(filePath);
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    die(`cannot read attachment ${filePath}: ${msg}`, 1);
  }
  const blob = new Blob([data]);
  const form = new FormData();
  form.append("file", blob, filename);
  const url = `${BOARD_URL}/api/cards/${cardId}/upload`;
  let res: Response;
  try {
    res = await fetch(url, { method: "POST", body: form });
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    die(`upload failed — ${msg}`, 2);
  }
  if (!res.ok) {
    const body = await res.text();
    die(`upload failed (${res.status}): ${body}`, 1);
  }
}

async function cmdCreate(args: ParsedArgs): Promise<void> {
  const title = flag(args, "title");
  if (!title) die("--title is required", 1);
  const priority = flag(args, "priority");
  const projectId = flag(args, "project-id") ?? flag(args, "project");
  const parentId = flag(args, "parent-id");
  const attachments = flagList(args, "attach");
  const cardType = flag(args, "type");
  const version = flag(args, "version");

  const body: Record<string, unknown> = { title };
  if (priority) body.priority = priority;
  if (projectId) body.projectId = projectId;
  if (parentId) body.parentId = parentId;
  if (cardType) body.cardType = cardType;
  if (version) body.version = version;

  const res = await apiClient<{ id?: string; error?: string }>("POST", "/cards", body);
  if (!res.ok) {
    die(`create failed (${res.status}): ${JSON.stringify(res.body)}`, 1);
  }
  const id = (res.body as { id: string }).id;

  for (const p of attachments) {
    const absPath = p.startsWith("/") ? p : `${process.cwd()}/${p}`;
    await uploadAttachment(id, absPath);
  }

  out(`created ${id}`);
}

async function cmdMove(args: ParsedArgs): Promise<void> {
  const [id, state] = args.positional;
  if (!id || !state) die("usage: board move <id> <state>", 1);

  const res = await apiClient<{ failures?: string[]; error?: string }>(
    "POST",
    `/cards/${id}/move`,
    { state },
  );

  if (res.status === 422) {
    const failures = (res.body as { failures?: string[] }).failures ?? [JSON.stringify(res.body)];
    for (const f of failures) {
      process.stdout.write(f + "\n");
    }
    process.exit(1);
  }
  if (!res.ok) {
    die(`move failed (${res.status}): ${JSON.stringify(res.body)}`, 2);
  }
  out(`moved ${id} to ${state}`);
}

async function cmdUpdate(args: ParsedArgs): Promise<void> {
  const [id] = args.positional;
  if (!id) die("usage: board update <id> [options]", 1);

  const body: Record<string, unknown> = {};
  const title = flag(args, "title");
  const priority = flag(args, "priority");
  const log = flag(args, "log");
  const attachments = flagList(args, "attach");
  const workdir = flag(args, "workdir");
  const version = flag(args, "version");
  const depsFlag = flag(args, "deps");

  if (title) body.title = title;
  if (priority) body.priority = priority;
  if (log) body.workLogEntry = { message: log, timestamp: new Date().toISOString() };
  if (workdir) body.workDir = workdir;
  if (version) body.version = version;
  if (depsFlag !== undefined) {
    body.deps = depsFlag === "" ? [] : depsFlag.split(",").map((s: string) => s.trim()).filter(Boolean);
  }

  // Send the base update (without attachments)
  const res = await apiClient<{ error?: string }>("PATCH", `/cards/${id}`, body);
  if (!res.ok) {
    die(`update failed (${res.status}): ${JSON.stringify(res.body)}`, 1);
  }

  // Upload each attachment via the file upload API so they get proper /uploads/ paths
  for (const p of attachments) {
    const absPath = p.startsWith("/") ? p : `${process.cwd()}/${p}`;
    await uploadAttachment(id, absPath);
  }

  out(`updated ${id}`);
}

async function cmdShow(args: ParsedArgs): Promise<void> {
  const [id] = args.positional;
  if (!id) die("usage: board show <id>", 1);

  const res = await apiClient<Record<string, unknown>>("GET", `/cards/${id}`);
  if (res.status === 404) die(`card not found: ${id}`, 1);
  if (!res.ok) die(`show failed (${res.status}): ${JSON.stringify(res.body)}`, 2);

  const card = res.body as {
    id: string;
    title: string;
    state: string;
    priority: string;
    attachments?: Array<{ path: string; name: string; fsPath?: string }>;
    workLog?: Array<{ message: string; timestamp: string }>;
    workDir?: string;
    createdAt: string;
    updatedAt: string;
    inProgressAt?: string;
    inReviewAt?: string;
    shippedAt?: string;
  };

  function fmtDuration(ms: number): string {
    const s = Math.floor(ms / 1000);
    if (s < 60) return `${s}s`;
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ${s % 60}s`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ${m % 60}m`;
    const d = Math.floor(h / 24);
    return `${d}d ${h % 24}h`;
  }

  const lines: string[] = [
    "---",
    `id: ${card.id}`,
    `title: ${card.title}`,
    `state: ${card.state}`,
    `priority: ${card.priority}`,
    `created: ${card.createdAt}`,
    `updated: ${card.updatedAt}`,
  ];
  if (card.workDir) lines.push(`workDir: ${card.workDir}`);
  if (card.attachments?.length) {
    // Resolve web-uploaded paths (/uploads/...) to absolute filesystem paths so agents can read them.
    // New uploads have fsPath set. Legacy uploads need the board's cwd to resolve the path.
    const hasLegacyUploads = card.attachments.some(
      (a) => !a.fsPath && a.path.startsWith("/uploads/")
    );
    let boardDir: string | null = null;
    if (hasLegacyUploads) {
      const bpRes = await apiClient<{ dir?: string }>("GET", "/board-path");
      if (bpRes.ok && bpRes.body?.dir) boardDir = bpRes.body.dir;
    }
    const resolvedPaths = card.attachments.map((a) => {
      if (a.fsPath) return a.fsPath;
      if (a.path.startsWith("/uploads/") && boardDir) return `${boardDir}/public${a.path}`;
      return a.path;
    });
    lines.push(`attachments:\n${resolvedPaths.map((p) => `  - ${p}`).join("\n")}`);
  }

  // Timing fields
  const createdMs = new Date(card.createdAt).getTime();
  if (card.inProgressAt) {
    const waitMs = new Date(card.inProgressAt).getTime() - createdMs;
    lines.push(`inProgressAt: ${card.inProgressAt}  (waited ${fmtDuration(waitMs)} in backlog)`);
  }
  if (card.inReviewAt) {
    const base = card.inProgressAt ? new Date(card.inProgressAt).getTime() : createdMs;
    const dur = new Date(card.inReviewAt).getTime() - base;
    lines.push(`inReviewAt: ${card.inReviewAt}  (${fmtDuration(dur)} in-progress)`);
  }
  if (card.shippedAt) {
    const base = card.inReviewAt
      ? new Date(card.inReviewAt).getTime()
      : card.inProgressAt
        ? new Date(card.inProgressAt).getTime()
        : createdMs;
    const dur = new Date(card.shippedAt).getTime() - base;
    const total = new Date(card.shippedAt).getTime() - createdMs;
    lines.push(`shippedAt: ${card.shippedAt}  (${fmtDuration(dur)} in-review, ${fmtDuration(total)} total)`);
  }

  lines.push("---", "");

  const workLog = card.workLog ?? [];
  if (workLog.length > 0) {
    lines.push("## Work Log", "");
    for (const entry of workLog) {
      lines.push(`**${entry.timestamp}** — ${entry.message}`, "");
    }
  }

  out(lines.join("\n"));
}

async function cmdSearch(args: ParsedArgs): Promise<void> {
  const params = new URLSearchParams();
  const state = flag(args, "state");
  const priority = flag(args, "priority");
  const text = flag(args, "text");
  const all = flag(args, "all");

  if (state) params.set("state", state);
  if (priority) params.set("priority", priority);
  if (text) params.set("text", text);
  if (all) params.set("all", "true");

  const qs = params.toString();
  const res = await apiClient<unknown[]>("GET", `/cards${qs ? `?${qs}` : ""}`);
  if (!res.ok) die(`search failed (${res.status}): ${JSON.stringify(res.body)}`, 2);

  const cards = res.body as Array<{
    id: string;
    title: string;
    state: string;
    priority: string;
  }>;

  const priorityOrder: Record<string, number> = { critical: 0, high: 1, normal: 2, low: 3 };
  cards.sort((a, b) => (priorityOrder[a.priority] ?? 99) - (priorityOrder[b.priority] ?? 99));

  if (cards.length === 0) {
    out("(no cards found)");
    return;
  }

  const idW = Math.max(4, ...cards.map((c) => c.id.length));
  const titleW = Math.max(5, ...cards.map((c) => c.title.length));
  const stateW = Math.max(5, ...cards.map((c) => c.state.length));
  const priW = Math.max(8, ...cards.map((c) => c.priority.length));

  const row = (id: string, title: string, state: string, pri: string) =>
    `${id.padEnd(idW)}  ${title.padEnd(titleW)}  ${state.padEnd(stateW)}  ${pri.padEnd(priW)}`;

  out(row("ID", "TITLE", "STATE", "PRIORITY"));
  out(row("-".repeat(idW), "-".repeat(titleW), "-".repeat(stateW), "-".repeat(priW)));
  for (const c of cards) {
    out(row(c.id, c.title, c.state, c.priority));
  }
}

async function cmdSettings(args: ParsedArgs): Promise<void> {
  const [sub, key, ...rest] = args.positional;

  if (sub === "list" || sub === undefined) {
    const res = await apiClient<Record<string, string>>("GET", "/settings");
    if (!res.ok) die(`settings failed (${res.status})`, 2);
    for (const [k, v] of Object.entries(res.body as Record<string, string>)) {
      out(`${k}: ${v}`);
    }
    return;
  }

  if (sub === "get") {
    if (!key) die("usage: board settings get <key>", 1);
    const res = await apiClient<Record<string, string>>("GET", "/settings");
    if (!res.ok) die(`settings failed (${res.status})`, 2);
    const val = (res.body as Record<string, string>)[key];
    if (val === undefined) die(`unknown setting: ${key}`, 1);
    out(val);
    return;
  }

  if (sub === "set") {
    if (!key) die("usage: board settings set <key> <value>", 1);
    const value = rest.join(" ");
    const res = await apiClient<Record<string, string>>("PATCH", "/settings", { [key]: value });
    if (!res.ok) die(`settings set failed (${res.status})`, 2);
    out(`set ${key}`);
    return;
  }

  die(`unknown settings subcommand: ${sub}. Valid: list, get, set`, 1);
}

async function cmdProject(args: ParsedArgs): Promise<void> {
  const [sub, ...rest] = args.positional;

  if (sub === "list" || sub === undefined) {
    const res = await apiClient<unknown[]>("GET", "/projects");
    if (!res.ok) die(`project list failed (${res.status})`, 2);
    const projects = res.body as Array<{ id: string; name: string; repoDir: string }>;
    if (projects.length === 0) { out("(no projects)"); return; }
    const idW = Math.max(4, ...projects.map(p => p.id.length));
    const nameW = Math.max(4, ...projects.map(p => p.name.length));
    out(`${"ID".padEnd(idW)}  ${"NAME".padEnd(nameW)}  REPO_DIR`);
    out(`${"-".repeat(idW)}  ${"-".repeat(nameW)}  --------`);
    for (const p of projects) out(`${p.id.padEnd(idW)}  ${p.name.padEnd(nameW)}  ${p.repoDir}`);
    return;
  }

  if (sub === "create") {
    const name = flag({ positional: rest, flags: args.flags }, "name") ?? flag(args, "name");
    const repoUrl = flag(args, "repo");
    const repoDir = flag(args, "repo-dir");
    const templateType = flag(args, "template");

    if (!name) die("--name is required", 1);

    let finalRepoDir = repoDir;

    if (repoUrl && !finalRepoDir) {
      // Derive workspace dir from settings
      const settingsRes = await apiClient<Record<string, string>>("GET", "/settings");
      const workspacesDir = settingsRes.ok
        ? (settingsRes.body as Record<string, string>).workspaces_dir || "~/workspaces"
        : "~/workspaces";
      const slug = name.trim().toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
      const expandedBase = workspacesDir.replace(/^~/, process.env.HOME ?? "~");
      finalRepoDir = `${expandedBase}/${slug}`;

      // Clone the repo
      const { spawnSync } = await import("node:child_process");
      const { mkdirSync } = await import("node:fs");
      try { mkdirSync(expandedBase, { recursive: true }); } catch {}
      out(`Cloning ${repoUrl} → ${finalRepoDir}…`);
      const result = spawnSync("git", ["clone", repoUrl, finalRepoDir], { stdio: "inherit" });
      if (result.status !== 0) die(`git clone failed (exit ${result.status})`, 2);
    }

    if (!finalRepoDir) {
      // No repo provided — create a fresh local git repo under workspaces_dir
      const settingsRes = await apiClient<Record<string, string>>("GET", "/settings");
      const workspacesDir = settingsRes.ok
        ? (settingsRes.body as Record<string, string>).workspaces_dir || "~/workspaces"
        : "~/workspaces";
      const slug = name.trim().toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
      const expandedBase = workspacesDir.replace(/^~/, process.env.HOME ?? "~");
      finalRepoDir = `${expandedBase}/${slug}`;

      const { spawnSync } = await import("node:child_process");
      const { mkdirSync, existsSync } = await import("node:fs");
      if (!existsSync(finalRepoDir)) {
        try { mkdirSync(finalRepoDir, { recursive: true }); } catch {}
        out(`Initializing local repo at ${finalRepoDir}…`);
        const result = spawnSync("git", ["init", finalRepoDir], { stdio: "inherit" });
        if (result.status !== 0) die(`git init failed (exit ${result.status})`, 2);
      }
    }

    // Scaffold files using the template adapter if --template was provided
    if (templateType) {
      const adapterModule = await import("../agent/src/templates/index");
      let adapter;
      try {
        adapter = adapterModule.getAdapter(templateType);
      } catch (err) {
        die(`unknown template type: "${templateType}". Valid: ${adapterModule.TEMPLATE_TYPES.join(", ")}`, 1);
      }
      out(`Scaffolding template "${templateType}" into ${finalRepoDir}…`);
      const slug = name.trim().toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
      adapter!.scaffold(slug, finalRepoDir!);
    }

    const res = await apiClient<{ id?: string; error?: string }>("POST", "/projects", {
      name: name.trim(),
      repoDir: finalRepoDir,
      ...(templateType ? { templateType } : {}),
    });
    if (!res.ok) die(`project create failed (${res.status}): ${JSON.stringify(res.body)}`, 1);
    const project = res.body as { id: string; name: string };
    out(`created project ${project.id} (${project.name})`);
    return;
  }

  if (sub === "get-by-name") {
    const name = rest[0] ?? flag(args, "name");
    if (!name) die("usage: board project get-by-name <name>", 1);
    const res = await apiClient<unknown[]>("GET", "/projects");
    if (!res.ok) die(`project list failed (${res.status})`, 2);
    const projects = res.body as Array<{ id: string; name: string; repoDir: string }>;
    const match = projects.find(p => p.name.toLowerCase() === name.toLowerCase());
    if (!match) die(`no project found with name: ${name}`, 1);
    out(match.id);
    return;
  }

  if (sub === "cards") {
    const projectId = rest[0];
    if (!projectId) die("usage: board project cards <project-id>", 1);
    const res = await apiClient<unknown>("GET", `/projects/${projectId}/cards`);
    if (res.status === 404) die(`project not found: ${projectId}`, 1);
    if (!res.ok) die(`project cards failed (${res.status}): ${JSON.stringify(res.body)}`, 2);
    const cards = res.body as Array<{ id: string; title: string; state: string; priority: string }>;
    if (cards.length === 0) { out("(no cards)"); return; }
    const idW = Math.max(2, ...cards.map(c => c.id.length));
    const titleW = Math.max(5, ...cards.map(c => c.title.length));
    const stateW = Math.max(5, ...cards.map(c => c.state.length));
    const priW = Math.max(8, ...cards.map(c => c.priority.length));
    const row = (id: string, title: string, state: string, pri: string) =>
      `${id.padEnd(idW)}  ${title.padEnd(titleW)}  ${state.padEnd(stateW)}  ${pri.padEnd(priW)}`;
    out(row("ID", "TITLE", "STATE", "PRIORITY"));
    out(row("-".repeat(idW), "-".repeat(titleW), "-".repeat(stateW), "-".repeat(priW)));
    for (const c of cards) out(row(c.id, c.title, c.state, c.priority));
    return;
  }

  if (sub === "chat") {
    const projectId = rest[0];
    if (!projectId) die("usage: board project chat <project-id>", 1);
    const send = flag(args, "send");

    if (send !== undefined) {
      // POST a new message
      const content = flag(args, "content");
      if (!content) die("usage: board project chat <project-id> --send --content <text>", 1);
      const role = flag(args, "role") ?? "user";
      const res = await apiClient<{ id?: string; error?: string }>(
        "POST",
        `/projects/${projectId}/chat`,
        { role, content },
      );
      if (res.status === 404) die(`project not found: ${projectId}`, 1);
      if (!res.ok) die(`project chat send failed (${res.status}): ${JSON.stringify(res.body)}`, 1);
      const msg = res.body as { id: string };
      out(msg.id);
      return;
    }

    // GET chat history
    const res = await apiClient<unknown>("GET", `/projects/${projectId}/chat`);
    if (res.status === 404) die(`project not found: ${projectId}`, 1);
    if (!res.ok) die(`project chat failed (${res.status}): ${JSON.stringify(res.body)}`, 2);
    const messages = res.body as Array<{ id: string; role: string; content: string; createdAt: string }>;
    if (messages.length === 0) { out("(no messages)"); return; }
    const tsW = Math.max(9, ...messages.map(m => m.createdAt.length));
    const roleW = Math.max(4, ...messages.map(m => m.role.length));
    const hRow = (ts: string, role: string, content: string) =>
      `${ts.padEnd(tsW)}  ${role.padEnd(roleW)}  ${content}`;
    out(hRow("TIMESTAMP", "ROLE", "CONTENT"));
    out(hRow("-".repeat(tsW), "-".repeat(roleW), "-".repeat(80)));
    for (const m of messages) {
      const truncated = m.content.length > 80 ? m.content.slice(0, 77) + "..." : m.content;
      out(hRow(m.createdAt, m.role, truncated));
    }
    return;
  }

  die(`unknown project subcommand: ${sub}. Valid: list, create, get-by-name, cards, chat`, 1);
}

async function cmdArchive(args: ParsedArgs): Promise<void> {
  const [id] = args.positional;
  if (!id) die("usage: board archive <id> [--reason <msg>]", 1);
  const reason = flag(args, "reason");

  const body: Record<string, unknown> = {};
  if (reason) body.reason = reason;

  const res = await apiClient<{ error?: string }>("POST", `/cards/${id}/archive`, body);
  if (!res.ok) die(`archive failed (${res.status}): ${JSON.stringify(res.body)}`, 1);
  out(`archived ${id}`);
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------

const argv = process.argv.slice(2);
if (argv.length === 0) {
  process.stderr.write(
    "Usage: board <command> [options]\n" +
      "Commands: create, move, update, show, search, archive, project\n",
  );
  process.exit(1);
}

const [command, ...rest] = argv;
const args = parseArgs(rest);

switch (command) {
  case "create":
    await cmdCreate(args);
    break;
  case "move":
    await cmdMove(args);
    break;
  case "update":
    await cmdUpdate(args);
    break;
  case "show":
    await cmdShow(args);
    break;
  case "search":
    await cmdSearch(args);
    break;
  case "archive":
    await cmdArchive(args);
    break;
  case "settings":
    await cmdSettings(args);
    break;
  case "project":
    await cmdProject(args);
    break;
  default:
    die(`unknown command: ${command}. Valid: create, move, update, show, search, archive, settings, project`, 1);
}
