#!/usr/bin/env bash
# reflection — nightly ST→LT memory consolidation for AM
#
# Examines short-term memories older than 48h and asks Claude to decide:
#   promote → write to LT (FTS5 + DB), archive the ST file
#   keep    → leave in ST (still actively relevant)
#   drop    → delete (obsolete, superseded)
#
# Each run produces:
#   - A dated log at workspaces/memory/logs/YYYY-MM-DD.log
#   - A JSON run record in the LT DB (reflection_runs table)
#   - Updated workspaces/memory/consolidate.log (tail of all runs)

set -euo pipefail

# ── Flags ─────────────────────────────────────────────────────────────────────
FORCE=0
for arg in "$@"; do
  [[ "$arg" == "--force" ]] && FORCE=1
done

AM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ST_DIR="$AM_ROOT/workspaces/memory/st"
LT_DB="$AM_ROOT/workspaces/memory/lt/memory.db"
WS_DIR="$AM_ROOT/workspaces"
ARCHIVE_DIR="$AM_ROOT/workspaces/memory/archive"
LOGS_DIR="$AM_ROOT/workspaces/memory/logs"
CONSOLIDATED_LOG="$AM_ROOT/workspaces/memory/consolidate.log"

RUN_DATE="$(date -u +%Y-%m-%d)"
RUN_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
RUN_LOG="$LOGS_DIR/${RUN_DATE}.log"
RUN_ID="$(python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || uuidgen | tr '[:upper:]' '[:lower:]')"

mkdir -p "$ARCHIVE_DIR" "$LOGS_DIR" "$(dirname "$LT_DB")"

log() {
  local msg="[${RUN_TS}] $*"
  echo "$msg" | tee -a "$RUN_LOG" >> "$CONSOLIDATED_LOG"
}

# ── Commit workspaces repo after write ────────────────────────────────────────
ws_commit() {
  local msg="$1"
  if [ -d "$WS_DIR/.git" ]; then
    git -C "$WS_DIR" add -A memory/ 2>/dev/null && \
    git -C "$WS_DIR" diff --cached --quiet 2>/dev/null || \
    git -C "$WS_DIR" commit -m "$msg" --quiet 2>/dev/null || true
  fi
}

# ── LT DB init ───────────────────────────────────────────────────────────────
lt_init() {
  sqlite3 "$LT_DB" <<'SQL'
CREATE TABLE IF NOT EXISTS memories (
  id    TEXT PRIMARY KEY,
  content TEXT NOT NULL,
  source  TEXT NOT NULL DEFAULT 'cli',
  topic   TEXT,
  term    TEXT NOT NULL DEFAULT 'lt',
  created_at TEXT NOT NULL
);
CREATE VIRTUAL TABLE IF NOT EXISTS memories_fts USING fts5(
  content,
  content='memories',
  content_rowid='rowid'
);
CREATE TRIGGER IF NOT EXISTS mem_ai AFTER INSERT ON memories BEGIN
  INSERT INTO memories_fts(rowid, content) VALUES (new.rowid, new.content);
END;
CREATE TRIGGER IF NOT EXISTS mem_ad AFTER DELETE ON memories BEGIN
  INSERT INTO memories_fts(memories_fts, rowid, content) VALUES('delete', old.rowid, old.content);
END;
CREATE TRIGGER IF NOT EXISTS mem_au AFTER UPDATE ON memories BEGIN
  INSERT INTO memories_fts(memories_fts, rowid, content) VALUES('delete', old.rowid, old.content);
  INSERT INTO memories_fts(rowid, content) VALUES(new.rowid, new.content);
END;

CREATE TABLE IF NOT EXISTS reflection_runs (
  id         TEXT PRIMARY KEY,
  run_at     TEXT NOT NULL,
  skipped    INTEGER NOT NULL DEFAULT 0,
  promoted   INTEGER NOT NULL DEFAULT 0,
  kept       INTEGER NOT NULL DEFAULT 0,
  dropped    INTEGER NOT NULL DEFAULT 0,
  log_path   TEXT,
  details    TEXT  -- JSON array of { slug, decision, lt_id? }
);
SQL
}

# ── Check if a file is older than 48h ────────────────────────────────────────
older_than_48h() {
  local file="$1"
  local mtime
  mtime="$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null)"
  local now; now="$(date +%s)"
  [[ $(( now - mtime )) -gt 172800 ]]
}

# ── Classify via Claude ───────────────────────────────────────────────────────
classify_memory() {
  local slug="$1"
  local content="$2"

  local existing_lt
  existing_lt="$(sqlite3 "$LT_DB" "SELECT COUNT(*) FROM memories WHERE content = '${content//\'/\'\'}';" 2>/dev/null || echo 0)"
  if [[ "$existing_lt" -gt 0 ]]; then
    echo "promote"  # duplicate — archive ST, already in LT
    return
  fi

  if ! command -v claude &>/dev/null; then
    echo "promote"  # no AI fallback: promote everything
    return
  fi

  local decision
  decision="$(printf 'You are managing memory consolidation for an AI agent system.\n\nShort-term memory entry (>48h old):\n\nSLUG: %s\nCONTENT:\n%s\n\nDecide. Reply with ONE word only:\n- promote  → durable lesson, broad reuse → move to long-term\n- keep     → still actively changing, check again tomorrow\n- drop     → obsolete, too specific, superseded\n\nOne word:' "$slug" "$content" \
    | claude --print 2>/dev/null \
    | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]' \
    | grep -oE 'promote|keep|drop' | head -1)"

  echo "${decision:-promote}"
}

# ── Promote ───────────────────────────────────────────────────────────────────
promote_to_lt() {
  local slug="$1"
  local content="$2"
  local file="$3"

  local id
  id="$(python3 -c 'import uuid; print(uuid.uuid4())' 2>/dev/null || uuidgen | tr '[:upper:]' '[:lower:]')"
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  sqlite3 "$LT_DB" "INSERT INTO memories(id,content,source,topic,term,created_at) VALUES('$id','${content//\'/\'\'}','reflection','$slug','lt','$now');"
  mv "$file" "$ARCHIVE_DIR/$(date -u +%Y%m%d)-$(basename "$file")"
  log "  promoted: $slug → LT id=$id"
  echo "$id"
}

# ── Main ──────────────────────────────────────────────────────────────────────
log "=== reflection run $RUN_ID ==="

lt_init

if ! compgen -G "$ST_DIR/*.md" > /dev/null 2>&1; then
  log "  no ST memories — nothing to process"
  sqlite3 "$LT_DB" "INSERT INTO reflection_runs(id,run_at,skipped,promoted,kept,dropped,log_path,details) VALUES('$RUN_ID','$RUN_TS',0,0,0,0,'$RUN_LOG','[]');"
  log "=== done: promoted=0 kept=0 dropped=0 skipped=0 ==="
  echo "promoted 0, kept 0, dropped 0"
  exit 0
fi

skipped=0; promoted=0; kept=0; dropped=0
details_json="["
first_detail=1

for file in "$ST_DIR"/*.md; do
  slug="$(basename "$file" .md)"
  RUN_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"  # refresh timestamp per entry

  if [[ "$FORCE" -eq 0 ]] && ! older_than_48h "$file"; then
    log "  skip (fresh <48h): $slug"
    ((skipped++)) || true
    continue
  fi

  local_bytes="$(wc -c < "$file" | tr -d ' ')"
  log "  classifying: $slug (${local_bytes}b)"

  content="$(cat "$file")"
  if [[ "$FORCE" -eq 1 ]]; then
    decision="promote"
  else
    decision="$(classify_memory "$slug" "$content")"
  fi
  log "  → $decision: $slug"

  lt_id=""
  case "$decision" in
    promote)
      lt_id="$(promote_to_lt "$slug" "$content" "$file")"
      ((promoted++)) || true
      ;;
    keep)
      ((kept++)) || true
      ;;
    drop)
      rm "$file"
      log "  dropped: $slug"
      ((dropped++)) || true
      ;;
    *)
      log "  unrecognised '$decision' — defaulting to promote"
      lt_id="$(promote_to_lt "$slug" "$content" "$file")"
      ((promoted++)) || true
      ;;
  esac

  [[ "$first_detail" -eq 0 ]] && details_json+=","
  first_detail=0
  if [[ -n "$lt_id" ]]; then
    details_json+="{\"slug\":\"$slug\",\"decision\":\"$decision\",\"lt_id\":\"$lt_id\"}"
  else
    details_json+="{\"slug\":\"$slug\",\"decision\":\"$decision\"}"
  fi
done

details_json+="]"

# Write run record to DB
RUN_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
sqlite3 "$LT_DB" "INSERT INTO reflection_runs(id,run_at,skipped,promoted,kept,dropped,log_path,details) VALUES('$RUN_ID','$RUN_TS','$skipped','$promoted','$kept','$dropped','$RUN_LOG','${details_json//\'/\'\'}');"

log "=== done: promoted=$promoted kept=$kept dropped=$dropped skipped=$skipped ==="
echo "promoted $promoted, kept $kept, dropped $dropped"

# Commit any changes to workspaces repo
if [[ "$promoted" -gt 0 || "$dropped" -gt 0 ]]; then
  ws_commit "memory: reflection promoted=$promoted dropped=$dropped"
fi
