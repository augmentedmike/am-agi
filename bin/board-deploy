#!/usr/bin/env bash
# board-deploy — zero-downtime deploy via atomic symlink swap
#
# board/.next → deployments/current → deployments/<timestamp>/
#
# Flow:
#   1. Build into .next.staging/  (no NEXT_DIST_DIR — no tsconfig mutation)
#   2. Gate: canary on 4222 from .next.staging/
#   3. Gate passes → mv .next.staging deployments/<timestamp>
#                  → ln -sfn <timestamp> deployments/current  (atomic)
#   4. Restart prod — reads .next → deployments/current → new build
#   5. Gate fails → .next.staging deleted, prod never touched
#
# Never uses NEXT_DIST_DIR so tsconfig.json is never mutated.
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
BOARD="$REPO/board"
DEPLOYMENTS="$BOARD/deployments"
PROD_LABEL="am.board"
PROD_PORT=4220
CANARY_PORT=4222
GUI_UID="$(id -u)"
PLIST="$HOME/Library/LaunchAgents/$PROD_LABEL.plist"
CANARY_PID=""
TS="$(date +%Y%m%dT%H%M%S)"
LOCK_DIR="/tmp/board-deploy.running"

mkdir -p "$DEPLOYMENTS"

# Ensure .next is a symlink (not a real directory)
if [ -e "$BOARD/.next" ] && [ ! -L "$BOARD/.next" ]; then
  echo "ERROR: $BOARD/.next is a real directory, not a symlink." >&2
  echo "Run: cp -r board/.next board/deployments/initial && ln -sfn initial board/deployments/current && rm -rf board/.next && ln -sfn deployments/current board/.next" >&2
  exit 1
fi

# Serialize concurrent deploys
waited=0
while ! mkdir "$LOCK_DIR" 2>/dev/null; do
  [ $waited -eq 0 ] && echo "board-deploy already running — waiting..."
  waited=$((waited + 2))
  [ $waited -ge 300 ] && { echo "ERROR: board-deploy timed out waiting for lock" >&2; exit 1; }
  sleep 2
done

cleanup() {
  rm -rf "$LOCK_DIR" 2>/dev/null || true
  [ -n "$CANARY_PID" ] && kill "$CANARY_PID" 2>/dev/null || true
  lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true
  rm -rf "$BOARD/.next.staging"
}
trap cleanup EXIT

cd "$BOARD"

# ── 1. Build into .next.staging/ ─────────────────────────────────────────────
echo "building → .next.staging/ (prod stays live on $PROD_PORT)..."
rm -rf "$BOARD/.next.staging"
# Absolute path required — relative NEXT_DIST_DIR breaks Turbopack subdirectory creation
NEXT_DIST_DIR="$BOARD/.next.staging" npm run build

# Fix native module symlinks immediately after build, using absolute paths.
# Turbopack creates relative symlinks (../../node_modules/pkg) that break when
# the directory is moved. Rewrite them to absolute paths now, before any mv.
STAGING_NM="$BOARD/.next.staging/node_modules"
if [ -d "$STAGING_NM" ]; then
  for link in "$STAGING_NM"/*; do
    [ -L "$link" ] || continue
    pkg=$(basename "$link" | sed 's/-[a-f0-9]*$//')
    real="$BOARD/node_modules/$pkg"
    [ -e "$real" ] && ln -sfn "$real" "$link"
  done
fi

# ── 2. Gate: canary on 4222 from .next.staging/ ──────────────────────────────
echo "gating canary on port $CANARY_PORT..."
lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true

NEXT_DIST_DIR="$BOARD/.next.staging" PORT=$CANARY_PORT \
  node_modules/.bin/next start --port $CANARY_PORT \
  >>/tmp/board-canary.log 2>&1 &
CANARY_PID=$!

gate_ok=0
for i in $(seq 1 20); do
  code=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$CANARY_PORT/" 2>/dev/null || echo 0)
  [ "$code" = "200" ] && { gate_ok=1; break; }
  sleep 1
done

kill "$CANARY_PID" 2>/dev/null || true; CANARY_PID=""
lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true

if [ "$gate_ok" = "0" ]; then
  echo "ERROR: canary gate failed — prod untouched. Check /tmp/board-canary.log" >&2
  exit 1
fi
echo "canary gate passed"

# ── 3. Promote: rename staging → versioned, swap symlink (atomic) ─────────────
echo "promoting .next.staging → deployments/$TS"
mv "$BOARD/.next.staging" "$DEPLOYMENTS/$TS"

ln -sfn "$TS" "$DEPLOYMENTS/current"
# cleanup trap won't find .next.staging (already moved), so no double-delete

# ── 4. Restart prod ───────────────────────────────────────────────────────────
# Kill only the next-server process — launchd KeepAlive restarts it immediately.
# Never use launchctl bootout/bootstrap: that creates a hard down window and
# orphaned next-server children that hold the port on the next start.
echo "restarting next-server (launchd will revive)..."
lsof -ti:$PROD_PORT | xargs kill -TERM 2>/dev/null || true
sleep 1

echo "waiting for prod on $PROD_PORT..."
for i in $(seq 1 20); do
  code=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$PROD_PORT/" 2>/dev/null || echo 0)
  [ "$code" = "200" ] && { echo "prod up → http://localhost:$PROD_PORT (build: $TS)"; exit 0; }
  sleep 1
done

echo "ERROR: prod did not come up — check /tmp/am-board.log" >&2
exit 1
