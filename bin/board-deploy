#!/usr/bin/env bash
# board-deploy — zero-downtime deploy via atomic symlink swap
#
# board/.next → deployments/current → deployments/<timestamp>/
#
# Flow:
#   1. Build into .next.staging/  (no NEXT_DIST_DIR — no tsconfig mutation)
#   2. Gate: canary on 4222 from .next.staging/
#   3. Gate passes → mv .next.staging deployments/<timestamp>
#                  → ln -sfn <timestamp> deployments/current  (atomic)
#   4. Restart prod — reads .next → deployments/current → new build
#   5. Gate fails → .next.staging deleted, prod never touched
#
# Never uses NEXT_DIST_DIR so tsconfig.json is never mutated.
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
BOARD="$REPO/board"
DEPLOYMENTS="$BOARD/deployments"
PROD_LABEL="am.board"
PROD_PORT=4220
CANARY_PORT=4222
CANARY_PID=""
TS="$(date +%Y%m%dT%H%M%S)"
PROMOTED_TS=""

# ── Spawn log — every invocation writes here so we can trace who called us ───
SPAWN_LOG="/tmp/board-deploy-spawns.log"
PARENT_CMD="$(ps -p $PPID -o comm= 2>/dev/null || echo unknown)"
PARENT_ARGS="$(ps -p $PPID -o args= 2>/dev/null | cut -c1-120 || echo unknown)"
echo "[$TS] board-deploy PID=$$ PPID=$PPID parent_cmd=$PARENT_CMD cwd=$(pwd)" >> "$SPAWN_LOG"
echo "  parent_args: $PARENT_ARGS" >> "$SPAWN_LOG"

mkdir -p "$DEPLOYMENTS"

# ── Guard: only run from ship-hook or explicit override ──────────────────────
# Agents running board-deploy directly race with ship-hook and leave broken builds.
# Set AM_BOARD_DEPLOY_ALLOWED=1 to bypass (e.g. manual admin deploys).
if [ "${AM_BOARD_DEPLOY_ALLOWED:-}" != "1" ]; then
  # Check if our parent chain includes ship-hook
  CALLER="$(ps -p $PPID -o args= 2>/dev/null || echo '')"
  if [[ "$CALLER" != *"ship-hook"* ]]; then
    echo "ERROR: board-deploy must be called from ship-hook. Set AM_BOARD_DEPLOY_ALLOWED=1 to override." >&2
    echo "[$TS] board-deploy PID=$$ EXIT: blocked — not called from ship-hook (caller: $CALLER)" >> "$SPAWN_LOG"
    exit 1
  fi
fi

# Ensure .next is a symlink (not a real directory)
if [ -e "$BOARD/.next" ] && [ ! -L "$BOARD/.next" ]; then
  echo "ERROR: $BOARD/.next is a real directory, not a symlink." >&2
  echo "Run: cp -r board/.next board/deployments/initial && ln -sfn initial board/deployments/current && rm -rf board/.next && ln -sfn deployments/current board/.next" >&2
  echo "[$TS] board-deploy PID=$$ EXIT: .next is not a symlink" >> "$SPAWN_LOG"
  exit 1
fi

# ── Deduplication + serialization ────────────────────────────────────────────
# LOCK_DIR  = deploy is currently running (held by builder)
# WAITER_DIR = one deploy is already queued (held by the single waiter)
#
# At most one waiter exists at any time. If a waiter already exists, this
# invocation exits immediately — the existing waiter will pick up the latest
# code when it runs.
LOCK_DIR="/tmp/board-deploy.lock"
WAITER_DIR="/tmp/board-deploy.waiter"

# Try to become the waiter; if another waiter exists, exit — we're redundant.
if ! mkdir "$WAITER_DIR" 2>/dev/null; then
  echo "board-deploy [$$]: deploy already queued, skipping (deduped)"
  echo "[$TS] board-deploy PID=$$ EXIT: deduplicated — waiter already exists" >> "$SPAWN_LOG"
  exit 0
fi

cleanup_waiter() { rm -rf "$WAITER_DIR" 2>/dev/null || true; }

# Spin-wait for the lock (the running deploy to finish)
echo "board-deploy [$$]: waiting for lock..."
echo "[$TS] board-deploy PID=$$ waiting for lock" >> "$SPAWN_LOG"
waited=0
until mkdir "$LOCK_DIR" 2>/dev/null; do
  sleep 1
  waited=$((waited + 1))
  [ $waited -ge 600 ] && {
    echo "ERROR: board-deploy lock timed out" >&2
    echo "[$TS] board-deploy PID=$$ EXIT: lock timed out after 600s" >> "$SPAWN_LOG"
    cleanup_waiter
    exit 1
  }
done
# We have the lock — release the waiter slot so new requests can queue
cleanup_waiter
echo "board-deploy [$$]: lock acquired"
echo "[$TS] board-deploy PID=$$ lock acquired (waited ${waited}s)" >> "$SPAWN_LOG"

PROMOTED_TS=""

cleanup() {
  rm -rf "$LOCK_DIR" 2>/dev/null || true
  cleanup_waiter 2>/dev/null || true
  [ -n "$CANARY_PID" ] && kill "$CANARY_PID" 2>/dev/null || true
  /usr/sbin/lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true
  rm -rf "$BOARD/.next.staging"
  # Remove a promoted-but-not-yet-symlinked deployment dir on failure
  if [ -n "$PROMOTED_TS" ]; then
    current_target="$(readlink "$DEPLOYMENTS/current" 2>/dev/null || true)"
    if [ "$current_target" != "$PROMOTED_TS" ]; then
      echo "cleanup: removing orphaned promoted dir deployments/$PROMOTED_TS" >&2
      rm -rf "${DEPLOYMENTS:?}/$PROMOTED_TS"
    fi
  fi
}
trap cleanup EXIT

cd "$BOARD"

# ── 1. Build into .next.staging/ ─────────────────────────────────────────────
echo "building → .next.staging/ (prod stays live on $PROD_PORT)..."
rm -rf "$BOARD/.next.staging"
NEXT_DIST_DIR=.next.staging npm run build

# Fix native module symlinks immediately after build, using absolute paths.
# Turbopack creates relative symlinks (../../node_modules/pkg) that break when
# the directory is moved. Rewrite them to absolute paths now, before any mv.
STAGING_NM="$BOARD/.next.staging/node_modules"
if [ -d "$STAGING_NM" ]; then
  for link in "$STAGING_NM"/*; do
    [ -L "$link" ] || continue
    pkg=$(basename "$link" | sed 's/-[a-f0-9]*$//')
    real="$BOARD/node_modules/$pkg"
    [ -e "$real" ] && ln -sfn "$real" "$link"
  done
fi

# ── 2. Gate: canary on 4222 from .next.staging/ ──────────────────────────────
echo "gating canary on port $CANARY_PORT..."
/usr/sbin/lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true

NEXT_DIST_DIR=.next.staging PORT=$CANARY_PORT DB_PATH="$BOARD/board.db" \
  node_modules/.bin/next start --port $CANARY_PORT \
  >>/tmp/board-canary.log 2>&1 &
CANARY_PID=$!

gate_ok=0
for i in $(seq 1 20); do
  code=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$CANARY_PORT/" 2>/dev/null || echo 0)
  [ "$code" = "200" ] && { gate_ok=1; break; }
  sleep 1
done

kill "$CANARY_PID" 2>/dev/null || true; CANARY_PID=""
/usr/sbin/lsof -ti:$CANARY_PORT | xargs kill -9 2>/dev/null || true

if [ "$gate_ok" = "0" ]; then
  echo "ERROR: canary gate failed — prod untouched. Check /tmp/board-canary.log" >&2
  exit 1
fi
echo "canary gate passed"

# ── 3. Promote: rename staging → versioned, swap symlink (atomic) ─────────────
echo "promoting .next.staging → deployments/$TS"
mv "$BOARD/.next.staging" "$DEPLOYMENTS/$TS"
PROMOTED_TS="$TS"

# Gate: ensure the staged build is complete before swapping the symlink
if [ ! -f "$DEPLOYMENTS/$TS/BUILD_ID" ]; then
  echo "ERROR: BUILD_ID missing in deployments/$TS — incomplete build, aborting promotion." >&2
  exit 1
fi

ln -sfn "$TS" "$DEPLOYMENTS/current"
# cleanup trap won't find .next.staging (already moved), so no double-delete

# ── 4. Restart prod ───────────────────────────────────────────────────────────
# Kill only the next-server process — launchd KeepAlive restarts it immediately.
# Never use launchctl bootout/bootstrap: that creates a hard down window and
# orphaned next-server children that hold the port on the next start.
echo "restarting next-server (launchd will revive)..."
/usr/sbin/lsof -ti:$PROD_PORT | xargs kill -KILL 2>/dev/null || true
sleep 1

echo "waiting for prod on $PROD_PORT..."
for i in $(seq 1 20); do
  code=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:$PROD_PORT/" 2>/dev/null || echo 0)
  [ "$code" = "200" ] && { echo "prod up → http://localhost:$PROD_PORT (build: $TS)"; exit 0; }
  sleep 1
done

echo "ERROR: prod did not come up — check /tmp/am-board.log" >&2
exit 1
