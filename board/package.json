{
  "name": "board",
  "version": "0.0.18",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 4221",
    "dev:bun": "echo 'Use npm run dev — bun cannot load better-sqlite3 native module' && exit 1",
    "build": "next build",
    "start": "next start --port 4220",
    "test": "bun test",
    "db:seed": "bun run src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "mime-types": "^3.0.2",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "pinyin-pro": "^3.28.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
  ]
}
